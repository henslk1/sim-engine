enum TreatmentType {
  OTC
  PRESCRIPTION
  VET_PROCEDURE
  ACTIVITY_RESTRICTION
  PLAYER_ACTION
}

enum ActivityRestrictionType {
  TRAINING
  COMPETITION
  BREEDING
  CARE_ACTION
  ALL
}

enum TestResultOutcome {
  POSITIVE
  NEGATIVE
  INCONCLUSIVE
}

model HealthConditionDef {
  id                     String                    @id @default(cuid())
  gameId                 String
  name                   String
  isGenetic              Boolean                   @default(false)
  isFatal                Boolean                   @default(false)
  moodEffect             Float?
  energyEffect           Float?
  behaviors              HealthConditionBehavior[]
  treatments             TreatmentDef[]
  healthRecords          AnimalHealthRecord[]
  testResults            AnimalTestResult[]
  groupEntryRequirements GroupEntryRequirement[]
  game                   Game                      @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model HealthConditionBehavior {
  id              String             @id @default(cuid())
  conditionDefId  String
  careActionDefId String?
  symptomText     String
  conditionDef    HealthConditionDef @relation(fields: [conditionDefId], references: [id])
  careActionDef   CareActionDef?     @relation(fields: [careActionDefId], references: [id])
}

model TreatmentDef {
  id               String                  @id @default(cuid())
  conditionDefId   String
  name             String
  treatmentType    TreatmentType
  durationCycles   Int?
  items            TreatmentItem[]
  treatmentRecords AnimalTreatmentRecord[]
  conditionDef     HealthConditionDef      @relation(fields: [conditionDefId], references: [id])
}

model TreatmentItem {
  id             String       @id @default(cuid())
  treatmentDefId String
  itemDefId      String
  quantity       Int          @default(1)
  treatmentDef   TreatmentDef @relation(fields: [treatmentDefId], references: [id])
  itemDef        ItemDef      @relation(fields: [itemDefId], references: [id])

  @@unique([treatmentDefId, itemDefId])
}

model AnimalHealthRecord {
  id               String                  @id @default(cuid())
  animalId         String
  conditionDefId   String
  diagnosedCycle   Int
  diagnosedAt      DateTime                @default(now())
  resolvedCycle    Int?
  resolvedAt       DateTime?
  isActive         Boolean                 @default(true)
  treatmentRecords AnimalTreatmentRecord[]
  animal           Animal                  @relation(fields: [animalId], references: [id])
  conditionDef     HealthConditionDef      @relation(fields: [conditionDefId], references: [id])
}

model AnimalTreatmentRecord {
  id                  String                @id @default(cuid())
  animalId            String
  treatmentDefId      String
  healthRecordId      String
  startedCycle        Int
  startedAt           DateTime              @default(now())
  completedCycle      Int?
  completedAt         DateTime?
  isActive            Boolean               @default(true)
  activityRestriction ActivityRestriction[]
  animal              Animal                @relation(fields: [animalId], references: [id])
  treatmentDef        TreatmentDef          @relation(fields: [treatmentDefId], references: [id])
  healthRecord        AnimalHealthRecord    @relation(fields: [healthRecordId], references: [id])
}

model ActivityRestriction {
  id                String                  @id @default(cuid())
  animalId          String
  treatmentRecordId String?
  restrictionType   ActivityRestrictionType
  maxIntensityTier  Int?
  remainingCycles   Int
  isActive          Boolean                 @default(true)
  animal            Animal                  @relation(fields: [animalId], references: [id])
  treatmentRecord   AnimalTreatmentRecord?  @relation(fields: [treatmentRecordId], references: [id])
}

model AnimalTestResult {
  id             String             @id @default(cuid())
  animalId       String
  conditionDefId String
  result         TestResultOutcome
  testedCycle    Int
  testedAt       DateTime           @default(now())
  animal         Animal             @relation(fields: [animalId], references: [id])
  conditionDef   HealthConditionDef @relation(fields: [conditionDefId], references: [id])
}

model HealthCertificateDef {
  id                     String              @id @default(cuid())
  gameId                 String
  name                   String
  validForCycles         Int
  requiredForCompetition Boolean             @default(false)
  certificates           HealthCertificate[]
  game                   Game                @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model HealthCertificate {
  id             String               @id @default(cuid())
  animalId       String
  certDefId      String
  issuedCycle    Int
  issuedAt       DateTime             @default(now())
  expiresAtCycle Int
  isValid        Boolean              @default(true)
  animal         Animal               @relation(fields: [animalId], references: [id])
  certDef        HealthCertificateDef @relation(fields: [certDefId], references: [id])

  @@unique([animalId, certDefId])
}

model VetVisitLog {
  id              String         @id @default(cuid())
  animalId        String
  playerAccountId String
  vetServiceDefId String?
  visitCycle      Int
  notes           String?
  visitedAt       DateTime       @default(now())
  vetServiceDef   VetServiceDef? @relation(fields: [vetServiceDefId], references: [id])
  animal          Animal         @relation(fields: [animalId], references: [id])
  playerAccount   PlayerAccount  @relation(fields: [playerAccountId], references: [id])
}

model AnimalImmunity {
  id        String   @id @default(cuid())
  animalId  String   @unique
  value     Float
  innateMax Float
  animal    Animal   @relation(fields: [animalId], references: [id])
  updatedAt DateTime @updatedAt
}
