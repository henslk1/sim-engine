enum ShopType {
  BASE
  PREMIUM
  VET
}

enum VetServiceType {
  EXAM
  PANEL_TEST
  GENETIC_COLLECTION
  GENETIC_STORAGE
  CASTRATION
  NATURAL_COVER
  ULTRASOUND
  PREGNANCY_ABORT
}

enum ListingType {
  ANIMAL
  ITEM
  GENETIC_MATERIAL
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

model StoreListing {
  id               String      @id @default(cuid())
  gameId           String
  itemDefId        String
  shopType         ShopType
  price            Int
  currencyDefId    String
  isActive         Boolean     @default(true)
  isRotating       Boolean     @default(false)
  rotationStartsAt DateTime?
  rotationEndsAt   DateTime?
  currencyDef      CurrencyDef @relation(fields: [currencyDefId], references: [id])
  itemDef          ItemDef     @relation(fields: [itemDefId], references: [id])
  game             Game        @relation(fields: [gameId], references: [id])
}

model PlayerStore {
  id              String               @id @default(cuid())
  gameId          String
  playerAccountId String               @unique
  name            String
  description     String?
  banner          String?
  listings        MarketplaceListing[]
  isActive        Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  playerAccount   PlayerAccount        @relation(fields: [playerAccountId], references: [id])
  game            Game                 @relation(fields: [gameId], references: [id])
}

model VetServiceDef {
  id                    String           @id @default(cuid())
  gameId                String
  name                  String
  serviceType           VetServiceType
  baseCost              Int
  currencyDefId         String
  hasSubscriberDiscount Boolean          @default(false)
  vetVisitLogs          VetVisitLog[]
  panelDefId            String?
  panelDef              GeneticPanelDef? @relation(fields: [panelDefId], references: [id])
  currencyDef           CurrencyDef      @relation(fields: [currencyDefId], references: [id])
  game                  Game             @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model Bundle {
  id              String                 @id @default(cuid())
  gameId          String
  name            String
  priceUsd        Int
  stripeProductId String?
  isActive        Boolean                @default(true)
  items           BundleItem[]
  currencies      BundleCurrencyReward[]
  animals         BundleAnimal[]
  game            Game                   @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model BundleItem {
  id        String  @id @default(cuid())
  bundleId  String
  itemDefId String
  quantity  Int     @default(1)
  itemDef   ItemDef @relation(fields: [itemDefId], references: [id])
  bundle    Bundle  @relation(fields: [bundleId], references: [id])

  @@unique([bundleId, itemDefId])
}

model BundleCurrencyReward {
  id            String      @id @default(cuid())
  bundleId      String
  currencyDefId String
  amount        Int
  currencyDef   CurrencyDef @relation(fields: [currencyDefId], references: [id])
  bundle        Bundle      @relation(fields: [bundleId], references: [id])

  @@unique([bundleId, currencyDefId])
}

model BundleAnimal {
  id       String @id @default(cuid())
  bundleId String
  breedId  String
  quantity Int    @default(1)
  breed    Breed  @relation(fields: [breedId], references: [id])
  bundle   Bundle @relation(fields: [bundleId], references: [id])

  @@unique([bundleId, breedId])
}

model GameShopBreedConfig {
  id                    String           @id @default(cuid())
  gameId                String
  breedId               String
  targetStock           Int
  price                 Int
  currencyDefId         String
  gameShopFloor         Float            @default(0)
  shopAlleleQualityBias Float            @default(0)
  isActive              Boolean          @default(true)
  rotationStartsAt      DateTime?
  rotationEndsAt        DateTime?
  shopAnimals           GameShopAnimal[]
  currencyDef           CurrencyDef      @relation(fields: [currencyDefId], references: [id])
  breed                 Breed            @relation(fields: [breedId], references: [id])
  game                  Game             @relation(fields: [gameId], references: [id])

  @@unique([gameId, breedId, currencyDefId])
}

model GameShopAnimal {
  id                String              @id @default(cuid())
  gameId            String
  animalId          String              @unique
  shopBreedConfigId String
  isAvailable       Boolean             @default(true)
  purchasedAt       DateTime?
  shopBreedConfig   GameShopBreedConfig @relation(fields: [shopBreedConfigId], references: [id])
  animal            Animal              @relation(fields: [animalId], references: [id])
  game              Game                @relation(fields: [gameId], references: [id])
}

model MarketplaceListing {
  id               String                              @id @default(cuid())
  gameId           String
  sellerPlayerId   String
  playerStoreId    String?
  listingType      ListingType
  currencyDefId    String
  price            Int
  status           ListingStatus
  description      String?
  expiresAt        DateTime?
  createdAt        DateTime                            @default(now())
  updatedAt        DateTime                            @updatedAt
  animals          MarketplaceListingAnimal[]
  items            MarketplaceListingItem[]
  geneticMaterials MarketplaceListingGeneticMaterial[]
  offers           MarketplaceOffer[]
  userReports      UserReport[]
  currencyDef      CurrencyDef                         @relation(fields: [currencyDefId], references: [id])
  sellerPlayer     PlayerAccount                       @relation(fields: [sellerPlayerId], references: [id])
  playerStore      PlayerStore?                        @relation(fields: [playerStoreId], references: [id])
  game             Game                                @relation(fields: [gameId], references: [id])
}

model MarketplaceListingAnimal {
  id        String             @id @default(cuid())
  listingId String
  animalId  String
  animal    Animal             @relation(fields: [animalId], references: [id])
  listing   MarketplaceListing @relation(fields: [listingId], references: [id])

  @@unique([listingId, animalId])
}

model MarketplaceListingItem {
  id        String             @id @default(cuid())
  listingId String
  itemDefId String
  quantity  Int
  itemDef   ItemDef            @relation(fields: [itemDefId], references: [id])
  listing   MarketplaceListing @relation(fields: [listingId], references: [id])

  @@unique([listingId, itemDefId])
}

model MarketplaceListingGeneticMaterial {
  id                String             @id @default(cuid())
  listingId         String
  geneticMaterialId String
  geneticMaterial   GeneticMaterial    @relation(fields: [geneticMaterialId], references: [id])
  listing           MarketplaceListing @relation(fields: [listingId], references: [id])

  @@unique([listingId, geneticMaterialId])
}

model MarketplaceOffer {
  id               String                            @id @default(cuid())
  listingId        String
  buyingPlayerId   String
  amount           Int?
  currencyDefId    String?
  status           OfferStatus
  createdAt        DateTime                          @default(now())
  animals          MarketplaceOfferAnimal[]
  items            MarketplaceOfferItem[]
  geneticMaterials MarketplaceOfferGeneticMaterial[]
  currencyDef      CurrencyDef?                      @relation(fields: [currencyDefId], references: [id])
  buyingPlayer     PlayerAccount                     @relation(fields: [buyingPlayerId], references: [id])
  listing          MarketplaceListing                @relation(fields: [listingId], references: [id])
}

model MarketplaceOfferAnimal {
  id       String           @id @default(cuid())
  offerId  String
  animalId String
  animal   Animal           @relation(fields: [animalId], references: [id])
  offer    MarketplaceOffer @relation(fields: [offerId], references: [id])

  @@unique([offerId, animalId])
}

model MarketplaceOfferItem {
  id        String           @id @default(cuid())
  offerId   String
  itemDefId String
  quantity  Int
  itemDef   ItemDef          @relation(fields: [itemDefId], references: [id])
  offer     MarketplaceOffer @relation(fields: [offerId], references: [id])

  @@unique([offerId, itemDefId])
}

model MarketplaceOfferGeneticMaterial {
  id                String           @id @default(cuid())
  offerId           String
  geneticMaterialId String
  geneticMaterial   GeneticMaterial  @relation(fields: [geneticMaterialId], references: [id])
  offer             MarketplaceOffer @relation(fields: [offerId], references: [id])

  @@unique([offerId, geneticMaterialId])
}

model CurrencyExchangeOrder {
  id                String        @id @default(cuid())
  gameId            String
  sellerPlayerId    String
  fromCurrencyDefId String
  toCurrencyDefId   String
  exchangeRate      Float
  amountOffered     Int
  amountRemaining   Int
  isFlagged         Boolean       @default(false)
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  toCurrency        CurrencyDef   @relation("ToCurrency", fields: [toCurrencyDefId], references: [id])
  fromCurrency      CurrencyDef   @relation("FromCurrency", fields: [fromCurrencyDefId], references: [id])
  sellerPlayer      PlayerAccount @relation(fields: [sellerPlayerId], references: [id])
  game              Game          @relation(fields: [gameId], references: [id])
}

model Escrow {
  id            String         @id @default(cuid())
  gameId        String
  fromPlayerId  String
  toPlayerId    String?
  currencyDefId String
  amount        Int
  status        EscrowStatus
  jobContractId String?        @unique
  releasedAt    DateTime?
  createdAt     DateTime       @default(now())
  currencyDef   CurrencyDef    @relation(fields: [currencyDefId], references: [id])
  jobContract   JobContract?   @relation(fields: [jobContractId], references: [id])
  toPlayer      PlayerAccount? @relation("EscrowTo", fields: [toPlayerId], references: [id])
  fromPlayer    PlayerAccount  @relation("EscrowFrom", fields: [fromPlayerId], references: [id])
  game          Game           @relation(fields: [gameId], references: [id])
}

model Gift {
  id                String           @id @default(cuid())
  gameId            String
  fromPlayerId      String
  toPlayerId        String
  itemDefId         String?
  itemQuantity      Int?
  animalId          String?
  currencyDefId     String?
  currencyAmount    Int?
  geneticMaterialId String?
  message           String?
  sentAt            DateTime         @default(now())
  geneticMaterial   GeneticMaterial? @relation(fields: [geneticMaterialId], references: [id])
  currencyDef       CurrencyDef?     @relation(fields: [currencyDefId], references: [id])
  animal            Animal?          @relation(fields: [animalId], references: [id])
  itemDef           ItemDef?         @relation(fields: [itemDefId], references: [id])
  toPlayer          PlayerAccount    @relation("GiftTo", fields: [toPlayerId], references: [id])
  fromPlayer        PlayerAccount    @relation("GiftFrom", fields: [fromPlayerId], references: [id])
  game              Game             @relation(fields: [gameId], references: [id])
}
