enum ItemType {
  AGING_BASE
  AGING_PREMIUM
  OTC_MEDICATION
  CARE_CONSUMABLE
  EQUIPMENT
  DIRECT_EFFECT
  PERMANENT_APPLIED
  ANIMAL_SLOT_EXPAND
  SUBCONTAINER_EXPAND
}

enum ItemCategory {
  AGING
  CARE
  HEALTH
  EQUIPMENT
  BREEDING
  STORAGE
  MISC
}

enum PermanentEffectType {
  IMMORTALITY
  SEX_CHANGE
  FREE_AGING
  BREEDING_SLOT_RAISE
  ENERGY_MAX_RAISE
  TWIN_CHANCE_RAISE
  TWIN_GUARANTEE
  STAGE_SKIP
}

model ItemDef {
  id                      String                           @id @default(cuid())
  gameId                  String
  name                    String
  description             String?
  itemType                ItemType
  category                ItemCategory
  effects                 Json?
  effectType              PermanentEffectType?
  storeListings           StoreListing[]
  bundleItems             BundleItem[]
  marketplaceListingItems MarketplaceListingItem[]
  marketplaceOfferItems   MarketplaceOfferItem[]
  gifts                   Gift[]
  raffleItemConfigs       RaffleItemConfig[]
  raffleItemSubmissions   RaffleItemSubmission[]
  rafflePrizeItems        RafflePrizeItem[]
  playerInventory         PlayerInventory[]
  careActionItems         CareActionItem[]
  treatmentItems          TreatmentItem[]
  equipment               AnimalEquipment[]
  appliedItems            AnimalAppliedItem[]
  dailyLogs               AnimalDailyLog[]
  groupInventory          GroupInventory[]
  campaignRewardTierItems CampaignRewardTierItem[]
  disciplineRequirements  DisciplineEquipmentRequirement[]
  prizeEligible           Boolean                          @default(true)
  isSellable              Boolean                          @default(true)
  game                    Game                             @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model PlayerInventory {
  id              String        @id @default(cuid())
  playerAccountId String
  itemDefId       String
  quantity        Int           @default(1)
  itemDef         ItemDef       @relation(fields: [itemDefId], references: [id])
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])

  @@unique([playerAccountId, itemDefId])
}

model AnimalAppliedItem {
  id                String        @id @default(cuid())
  animalId          String
  itemDefId         String
  appliedByPlayerId String
  appliedAt         DateTime      @default(now())
  isConsumed        Boolean       @default(false)
  consumedAt        DateTime?
  appliedByPlayer   PlayerAccount @relation(fields: [appliedByPlayerId], references: [id])
  itemDef           ItemDef       @relation(fields: [itemDefId], references: [id])
  animal            Animal        @relation(fields: [animalId], references: [id])
}

model PlayerCapacity {
  id                       String        @id @default(cuid())
  playerAccountId          String        @unique
  animalSlotBase               Int
  animalSlotSubscription       Int           @default(0)
  animalSlotPurchased          Int           @default(0)
  subContainerBase             Int
  subContainerSubscription     Int           @default(0)
  subContainerPurchased        Int           @default(0)
  geneticStorageBase           Int           @default(50)
  geneticStorageSubscription   Int           @default(0)
  geneticStoragePurchased      Int           @default(0)
  playerAccount                PlayerAccount @relation(fields: [playerAccountId], references: [id])
}

model SubContainer {
  id              String        @id @default(cuid())
  playerAccountId String
  name            String
  animals         Animal[]
  displayOrder    Int
  sortDefault     String?
  filterConfig    Json?
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])
}
