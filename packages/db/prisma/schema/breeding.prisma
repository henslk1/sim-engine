enum BreedingSlotStatus {
  AVAILABLE
  PURCHASED
  USED
  EXPIRED
}

enum GeneticMaterialType {
  SPERM
  EGG
  EMBRYO
}

enum GeneticStorageType {
  PERSONAL
  VET
  GROUP
}

model BreedingListing {
  id                String                            @id @default(cuid())
  gameId            String
  ownerPlayerId     String
  animalId          String
  description       String?
  currencyDefId     String?
  pricePerSlot      Int
  maxSlots          Int?
  breedRestrictions BreedingListingBreedRestriction[]
  statMinimums      BreedingListingStatMinimum[]
  slots             BreedingSlot[]
  isActive          Boolean                           @default(true)
  animal            Animal                            @relation(fields: [animalId], references: [id])
  ownerPlayer       PlayerAccount                     @relation(fields: [ownerPlayerId], references: [id])
  currencyDef       CurrencyDef?                      @relation(fields: [currencyDefId], references: [id])
  game              Game                              @relation(fields: [gameId], references: [id])
  createdAt         DateTime                          @default(now())
  updatedAt         DateTime                          @updatedAt
}

model BreedingListingBreedRestriction {
  id        String          @id @default(cuid())
  listingId String
  breedId   String
  breed     Breed           @relation(fields: [breedId], references: [id])
  listing   BreedingListing @relation(fields: [listingId], references: [id])

  @@unique([listingId, breedId])
}

model BreedingListingStatMinimum {
  id        String          @id @default(cuid())
  listingId String
  statDefId String
  minValue  Float
  statDef   StatDef         @relation(fields: [statDefId], references: [id])
  listing   BreedingListing @relation(fields: [listingId], references: [id])

  @@unique([listingId, statDefId])
}

model BreedingSlot {
  id                  String             @id @default(cuid())
  listingId           String
  purchasedByPlayerId String?
  status              BreedingSlotStatus
  purchasedAt         DateTime?
  breedingRecord      BreedingRecord?
  listing             BreedingListing    @relation(fields: [listingId], references: [id])
  purchasedByPlayer   PlayerAccount?     @relation(fields: [purchasedByPlayerId], references: [id])
  createdAt           DateTime           @default(now())
}

model BreedingRecord {
  id                String           @id @default(cuid())
  gameId            String
  sireId            String
  damId             String
  breedingSlotId    String?          @unique
  geneticMaterialId String?          @unique
  sireSnapshot      Json
  damSnapshot       Json
  pregnancy         Pregnancy?
  geneticMaterial   GeneticMaterial? @relation("UsedMaterial", fields: [geneticMaterialId], references: [id])
  producedEmbryo    GeneticMaterial? @relation("ProducedBy")
  breedingSlot      BreedingSlot?    @relation(fields: [breedingSlotId], references: [id])
  dam               Animal           @relation("BreedingDam", fields: [damId], references: [id])
  sire              Animal           @relation("BreedingSire", fields: [sireId], references: [id])
  game              Game             @relation(fields: [gameId], references: [id])
  createdAt         DateTime         @default(now())
}

model GeneticMaterial {
  id                         String                              @id @default(cuid())
  gameId                     String
  animalId                   String
  ownerPlayerId              String
  groupId                    String?
  donorSnapshot              Json?
  offspringSnapshot          Json?
  inbreedingCoefficient      Float?
  producedByBreedingRecordId String?                             @unique
  materialType               GeneticMaterialType
  storageType                GeneticStorageType
  surrogacyRecord            SurrogacyRecord?
  marketplaceListings        MarketplaceListingGeneticMaterial[]
  marketplaceOffers          MarketplaceOfferGeneticMaterial[]
  gifts                      Gift[]
  rafflePrizes               RafflePrizeGeneticMaterial[]
  usedInRecord               BreedingRecord?                     @relation("UsedMaterial")
  producedByRecord           BreedingRecord?                     @relation("ProducedBy", fields: [producedByBreedingRecordId], references: [id])
  ownerPlayer                PlayerAccount                       @relation(fields: [ownerPlayerId], references: [id])
  group                      Group?                              @relation(fields: [groupId], references: [id])
  animal                     Animal                              @relation(fields: [animalId], references: [id])
  game                       Game                                @relation(fields: [gameId], references: [id])
  expiresAt                  DateTime?
  isUsed                     Boolean                             @default(false)
  collectedAt                DateTime                            @default(now())
}

model Pregnancy {
  id                 String               @id @default(cuid())
  animalId           String
  breedingRecordId   String               @unique
  isSurrogate        Boolean              @default(false)
  gestationStartedAt DateTime             @default(now())
  currentCycles      Int                  @default(0)
  requiredCycles     Int
  isCompleted        Boolean              @default(false)
  completedAt        DateTime?
  offspring          PregnancyOffspring[]
  surrogacyRecord    SurrogacyRecord?
  breedingRecord     BreedingRecord       @relation(fields: [breedingRecordId], references: [id])
  animal             Animal               @relation(fields: [animalId], references: [id])
}

model PregnancyOffspring {
  id          String    @id @default(cuid())
  animalId    String
  pregnancyId String
  birthOrder  Int?
  pregnancy   Pregnancy @relation(fields: [pregnancyId], references: [id])
  animal      Animal    @relation(fields: [animalId], references: [id])

  @@unique([pregnancyId, animalId])
}

model SurrogacyRecord {
  id                String           @id @default(cuid())
  pregnancyId       String           @unique
  biologicalDamId   String
  geneticMaterialId String?          @unique
  implantedAt       DateTime         @default(now())
  geneticMaterial   GeneticMaterial? @relation(fields: [geneticMaterialId], references: [id])
  biologicalDam     Animal           @relation(fields: [biologicalDamId], references: [id])
  pregnancy         Pregnancy        @relation(fields: [pregnancyId], references: [id])
}
