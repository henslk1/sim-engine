enum VenueClimate {
  HOT
  WARM
  COLD
  TEMPERATE
}

enum VenueTerrain {
  FLAT
  COASTAL
  HILLY
  MOUNTAIN
}

enum CompetitionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SeasonCategoryType {
  OVERALL
  PER_BREED
  PER_DISCIPLINE
}

enum RankSubjectType {
  PLAYER
  GROUP
}

model DisciplineDef {
  id                     String                           @id @default(cuid())
  gameId                 String
  name                   String
  description            String?
  isConformation         Boolean                          @default(false)
  statWeights            DisciplineStatWeight[]
  personalityWeights     DisciplinePersonalityWeight[]
  compTierDefs           CompetitionTierDef[]
  venueDisciplines       VenueDiscipline[]
  competitions           Competition[]
  animalCompTiers        AnimalCompetitionTier[]
  weeklyPoints           AnimalWeeklyPoints[]
  seasonCategories       SeasonCategory[]
  recordDefs             RecordDef[]
  titleDefs              TitleDef[]
  animals                Animal[]
  groups                 Group[]
  equipmentRequirements  DisciplineEquipmentRequirement[]
  game                   Game                             @relation(fields: [gameId], references: [id])
  groupEntryRequirements GroupEntryRequirement[]

  @@unique([gameId, name])
}

model DisciplineStatWeight {
  id              String        @id @default(cuid())
  disciplineDefId String
  statDefId       String
  weight          Float
  statDef         StatDef       @relation(fields: [statDefId], references: [id])
  disciplineDef   DisciplineDef @relation(fields: [disciplineDefId], references: [id])

  @@unique([disciplineDefId, statDefId])
}

model BreedConformationStandard {
  id                   String @id @default(cuid())
  breedId              String
  locusId              String
  idealExpressionLabel String
  weight               Float
  locus                Locus  @relation(fields: [locusId], references: [id])
  breed                Breed  @relation(fields: [breedId], references: [id])

  @@unique([breedId, locusId])
}

model CompetitionTierDef {
  id                             String                  @id @default(cuid())
  gameId                         String
  disciplineDefId                String
  name                           String
  tierIndex                      Int
  minScore                       Float?
  advancementThreshold           Float?
  energyCost                     Float                   @default(0)
  entryFee                       Int
  minWeeklyPointsForInvitational Float?
  animalTiers                    AnimalCompetitionTier[]
  tierPrizes                     CompetitionTierPrize[]
  disciplineDef                  DisciplineDef           @relation(fields: [disciplineDefId], references: [id])
  game                           Game                    @relation(fields: [gameId], references: [id])

  @@unique([disciplineDefId, tierIndex])
}

model Venue {
  id            String            @id @default(cuid())
  gameId        String
  name          String
  climate       VenueClimate
  terrain       VenueTerrain
  groupId       String?           @unique
  rotationOrder Int?
  disciplines   VenueDiscipline[]
  competitions  Competition[]
  group         Group?            @relation(fields: [groupId], references: [id])
  game          Game              @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model VenueDiscipline {
  id                       String        @id @default(cuid())
  venueId                  String
  disciplineDefId          String
  defaultMaxEntries        Int
  defaultMaxWaitHours      Int
  invitationalMaxEntries   Int?
  invitationalMaxWaitHours Int?
  competitionsPerDay       Int           @default(1)
  isInvitationalEligible   Boolean       @default(false)
  disciplineDef            DisciplineDef @relation(fields: [disciplineDefId], references: [id])
  venue                    Venue         @relation(fields: [venueId], references: [id])

  @@unique([venueId, disciplineDefId])
}

model ExpressionClimateModifier {
  id               String         @id @default(cuid())
  expressionRuleId String
  climate          VenueClimate
  modifier         Float
  expressionRule   ExpressionRule @relation(fields: [expressionRuleId], references: [id])

  @@unique([expressionRuleId, climate])
}

model ExpressionTerrainModifier {
  id               String         @id @default(cuid())
  expressionRuleId String
  terrain          VenueTerrain
  modifier         Float
  expressionRule   ExpressionRule @relation(fields: [expressionRuleId], references: [id])

  @@unique([expressionRuleId, terrain])
}

model Season {
  id           String           @id @default(cuid())
  gameId       String
  name         String
  startsAt     DateTime
  endsAt       DateTime
  isActive     Boolean          @default(false)
  categories   SeasonCategory[]
  rankings     SeasonRanking[]
  competitions Competition[]
  game         Game             @relation(fields: [gameId], references: [id])
}

model SeasonCategory {
  id              String             @id @default(cuid())
  seasonId        String
  name            String
  categoryType    SeasonCategoryType
  breedId         String?
  disciplineDefId String?
  rankings        SeasonRanking[]
  disciplineDef   DisciplineDef?     @relation(fields: [disciplineDefId], references: [id])
  breed           Breed?             @relation(fields: [breedId], references: [id])
  season          Season             @relation(fields: [seasonId], references: [id])

  @@unique([seasonId, name])
}

model RecordDef {
  id              String         @id @default(cuid())
  gameId          String
  name            String
  description     String?
  recordType      String
  subjectType     String
  disciplineDefId String?
  breedId         String?
  statDefId       String?
  entries         RecordEntry[]
  statDef         StatDef?       @relation(fields: [statDefId], references: [id])
  breed           Breed?         @relation(fields: [breedId], references: [id])
  disciplineDef   DisciplineDef? @relation(fields: [disciplineDefId], references: [id])
  game            Game           @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model DirectoryFilterDef {
  id           String  @id @default(cuid())
  gameId       String
  filterKey    String
  displayLabel String
  filterType   String
  isEnabled    Boolean @default(true)
  sortOrder    Int?
  game         Game    @relation(fields: [gameId], references: [id])

  @@unique([gameId, filterKey])
}

model Competition {
  id                 String             @id @default(cuid())
  gameId             String
  venueId            String
  disciplineDefId    String
  seasonId           String?
  name               String
  maxEntries         Int
  maxWaitHours       Int
  breedId            String?
  status             CompetitionStatus
  isInvitational     Boolean            @default(false)
  entries            CompetitionEntry[]
  campaignPhaseDefId String?
  breed              Breed?             @relation(fields: [breedId], references: [id])
  campaignPhase      CampaignPhaseDef?  @relation(fields: [campaignPhaseDefId], references: [id])
  season             Season?            @relation(fields: [seasonId], references: [id])
  disciplineDef      DisciplineDef      @relation(fields: [disciplineDefId], references: [id])
  venue              Venue              @relation(fields: [venueId], references: [id])
  game               Game               @relation(fields: [gameId], references: [id])
  createdAt          DateTime           @default(now())
  expiresAt          DateTime
}

model CompetitionEntry {
  id              String             @id @default(cuid())
  competitionId   String
  animalId        String
  playerAccountId String
  enteredAt       DateTime           @default(now())
  result          CompetitionResult?
  playerAccount   PlayerAccount      @relation(fields: [playerAccountId], references: [id])
  animal          Animal             @relation(fields: [animalId], references: [id])
  competition     Competition        @relation(fields: [competitionId], references: [id])

  @@unique([competitionId, animalId])
}

model CompetitionResult {
  id        String           @id @default(cuid())
  entryId   String           @unique
  placement Int?
  score     Float
  entry     CompetitionEntry @relation(fields: [entryId], references: [id])
}

model AnimalCompetitionTier {
  id              String             @id @default(cuid())
  animalId        String
  disciplineDefId String
  tierDefId       String
  tierDef         CompetitionTierDef @relation(fields: [tierDefId], references: [id])
  disciplineDef   DisciplineDef      @relation(fields: [disciplineDefId], references: [id])
  animal          Animal             @relation(fields: [animalId], references: [id])

  @@unique([animalId, disciplineDefId])
}

model AnimalWeeklyPoints {
  id              String        @id @default(cuid())
  animalId        String
  disciplineDefId String
  weekStart       DateTime
  points          Float
  disciplineDef   DisciplineDef @relation(fields: [disciplineDefId], references: [id])
  animal          Animal        @relation(fields: [animalId], references: [id])

  @@unique([animalId, disciplineDefId, weekStart])
}

model SeasonRanking {
  id              String          @id @default(cuid())
  seasonId        String
  categoryId      String
  subjectTypeId   RankSubjectType
  playerAccountId String?
  groupId         String?
  rank            Int
  score           Float
  group           Group?          @relation(fields: [groupId], references: [id])
  playerAccount   PlayerAccount?  @relation(fields: [playerAccountId], references: [id])
  category        SeasonCategory  @relation(fields: [categoryId], references: [id])
  season          Season          @relation(fields: [seasonId], references: [id])
}

model RecordEntry {
  id              String         @id @default(cuid())
  recordDefId     String
  playerAccountId String?
  animalId        String?
  groupId         String?
  value           Float
  setAt           DateTime       @default(now())
  group           Group?         @relation(fields: [groupId], references: [id])
  animal          Animal?        @relation(fields: [animalId], references: [id])
  playerAccount   PlayerAccount? @relation(fields: [playerAccountId], references: [id])
  recordDef       RecordDef      @relation(fields: [recordDefId], references: [id])
}

model DisciplinePersonalityWeight {
  id              String              @id @default(cuid())
  disciplineDefId String
  traitDefId      String
  weight          Float
  disciplineDef   DisciplineDef       @relation(fields: [disciplineDefId], references: [id])
  traitDef        PersonalityTraitDef @relation(fields: [traitDefId], references: [id])

  @@unique([disciplineDefId, traitDefId])
}

model CompetitionTierPrize {
  id             String             @id @default(cuid())
  tierDefId      String
  placement      Int
  currencyDefId  String?
  amount         Int
  isInvitational Boolean            @default(false)
  tierDef        CompetitionTierDef @relation(fields: [tierDefId], references: [id])
  currencyDef    CurrencyDef?       @relation(fields: [currencyDefId], references: [id])

  @@unique([tierDefId, placement, isInvitational])
}

model DisciplineEquipmentRequirement {
  id              String        @id @default(cuid())
  disciplineDefId String
  itemDefId       String
  quantity        Int           @default(1)
  disciplineDef   DisciplineDef @relation(fields: [disciplineDefId], references: [id])
  itemDef         ItemDef       @relation(fields: [itemDefId], references: [id])

  @@unique([disciplineDefId, itemDefId])
}
