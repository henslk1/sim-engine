enum GeneticPanelType {
  HEALTH
  CONFORMATION
}

enum LocusBiasTarget {
  FAVORABILITY
  RARITY
  NONE
}

model Locus {
  id                     String                      @id @default(cuid())
  gameId                 String
  name                   String
  displayGroup           String?
  biasTarget             LocusBiasTarget             @default(NONE)
  minTestCycle           Int?
  alleles                Allele[]
  expressionRules        ExpressionRule[]
  panelEntries           GeneticPanelLocus[]
  animalGenotypes        AnimalGenotype[]
  conformationStandards  BreedConformationStandard[]
  sectionEntries         ConformationSectionEntry[]
  groupEntryRequirements GroupEntryRequirement[]
  templateGenotypes      AnimalTemplateGenotype[]
  dqTraits               BreedDqTrait[]
  game                   Game                        @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model Allele {
  id                          String                   @id @default(cuid())
  locusId                     String
  symbol                      String
  availabilityState           GeneAvailabilityState?
  expressionRulesAsAlleleOne  ExpressionRule[]         @relation("AlleleOne")
  expressionRulesAsAlleleTwo  ExpressionRule[]         @relation("AlleleTwo")
  genotypesAsAlleleOne        AnimalGenotype[]         @relation("AlleleOne")
  genotypesAsAlleleTwo        AnimalGenotype[]         @relation("AlleleTwo")
  frequencies                 BreedAlleleFrequency[]
  templateGenotypeAsAlleleOne AnimalTemplateGenotype[] @relation("TemplateAlleleOne")
  templateGenotypeAsAlleleTwo AnimalTemplateGenotype[] @relation("TemplateAlleleTwo")

  locus Locus @relation(fields: [locusId], references: [id])

  @@unique([locusId, symbol])
}

model ExpressionRule {
  id                   String                      @id @default(cuid())
  locusId              String
  alleleOneId          String
  alleleTwoId          String
  phenotype            String
  numericModifier      Float?
  penetrance           Float?
  healthConditionDefId String?
  climateModifiers     ExpressionClimateModifier[]
  terrainModifiers     ExpressionTerrainModifier[]
  locus                Locus                       @relation(fields: [locusId], references: [id])
  alleleOne            Allele                      @relation("AlleleOne", fields: [alleleOneId], references: [id])
  alleleTwo            Allele                      @relation("AlleleTwo", fields: [alleleTwoId], references: [id])
  healthConditionDef   HealthConditionDef?         @relation(fields: [healthConditionDefId], references: [id])

  @@unique([locusId, alleleOneId, alleleTwoId])
}

model GeneAvailabilityState {
  id              String    @id @default(cuid())
  alleleId        String    @unique
  isAvailable     Boolean   @default(false)
  madeAvailableAt DateTime?
  allele          Allele    @relation(fields: [alleleId], references: [id])
}

model GeneticPanelDef {
  id                     String                  @id @default(cuid())
  gameId                 String
  name                   String
  panelType              GeneticPanelType
  loci                   GeneticPanelLocus[]
  vetServiceDefs         VetServiceDef[]
  groupEntryRequirements GroupEntryRequirement[]
  game                   Game                    @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model GeneticPanelLocus {
  id         String          @id @default(cuid())
  panelDefId String
  locusId    String
  panelDef   GeneticPanelDef @relation(fields: [panelDefId], references: [id])
  locus      Locus           @relation(fields: [locusId], references: [id])

  @@unique([panelDefId, locusId])
}

model BreedAlleleFrequency {
  id        String  @id @default(cuid())
  alleleId  String
  breedId   String
  frequency Float
  isDq      Boolean @default(false)
  allele    Allele  @relation(fields: [alleleId], references: [id])
  breed     Breed   @relation(fields: [breedId], references: [id])

  @@unique([breedId, alleleId])
}

model AnimalGenotype {
  id              String    @id @default(cuid())
  animalId        String
  locusId         String
  alleleOneId     String
  alleleTwoId     String
  isTestedByOwner Boolean   @default(false)
  testedAt        DateTime?
  testedCycle     Int?
  animal          Animal    @relation(fields: [animalId], references: [id])
  locus           Locus     @relation(fields: [locusId], references: [id])
  alleleOne       Allele    @relation("AlleleOne", fields: [alleleOneId], references: [id])
  alleleTwo       Allele    @relation("AlleleTwo", fields: [alleleTwoId], references: [id])

  @@unique([animalId, locusId])
}

model AnimalConformationScore {
  id           String   @id @default(cuid())
  animalId     String
  breedId      String
  score        Float
  calculatedAt DateTime @default(now())
  animal       Animal   @relation(fields: [animalId], references: [id])
  breed        Breed    @relation(fields: [breedId], references: [id])

  @@unique([animalId, breedId])
}

model ConformationSection {
  id            String                           @id @default(cuid())
  gameId        String
  name          String
  displayOrder  Int                              @default(0)
  entries       ConformationSectionEntry[]
  sectionScores AnimalConformationSectionScore[]
  game          Game                             @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model ConformationSectionEntry {
  id           String              @id @default(cuid())
  sectionId    String
  locusId      String
  displayOrder Int                 @default(0)
  section      ConformationSection @relation(fields: [sectionId], references: [id])
  locus        Locus               @relation(fields: [locusId], references: [id])

  @@unique([sectionId, locusId])
}

model AnimalConformationSectionScore {
  id           String              @id @default(cuid())
  animalId     String
  breedId      String
  sectionId    String
  score        Float
  calculatedAt DateTime            @default(now())
  animal       Animal              @relation(fields: [animalId], references: [id])
  breed        Breed               @relation(fields: [breedId], references: [id])
  section      ConformationSection @relation(fields: [sectionId], references: [id])

  @@unique([animalId, breedId, sectionId])
}
