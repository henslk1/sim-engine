enum BreedProposalStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  IN_VOTE
  SELECTED
}

enum BreedCampaignStatus {
  ACTIVE
  COMPLETED
}

enum CampaignPhaseType {
  ANNOUNCEMENT
  FOUNDATION
  PROVING
  GROWTH
  RECOGNITION
}

enum PhaseTriggerType {
  TIME
  ADMIN_MANUAL
}

enum AnimalStatMode {
  BREED_MAX
  FLOOR
  EXACT
}

enum PersonalityMode {
  RANDOM
  RANGE
}

enum CampaignRewardStatus {
  PENDING
  DISTRIBUTED
}

model BreedProposal {
  id                String              @id @default(cuid())
  gameId            String
  proposingPlayerId String
  name              String
  lore              String?
  ancestry          String?
  geneticPool       String?
  breedStandard     String?
  status            BreedProposalStatus
  adminFeedback     String?
  createdAt         DateTime            @default(now())
  reviewedAt        DateTime?
  votingStartedAt   DateTime?
  selectedAt        DateTime?
  votes             BreedProposalVote[]
  campaign          BreedCampaign?
  proposingPlayer   PlayerAccount       @relation(fields: [proposingPlayerId], references: [id])
  game              Game                @relation(fields: [gameId], references: [id])
}

model BreedProposalVote {
  id            String        @id @default(cuid())
  proposalId    String
  voterPlayerId String
  createdAt     DateTime      @default(now())
  proposal      BreedProposal @relation(fields: [proposalId], references: [id])
  voterPlayer   PlayerAccount @relation(fields: [voterPlayerId], references: [id])

  @@unique([proposalId, voterPlayerId])
}

model BreedCampaign {
  id                String                 @id @default(cuid())
  gameId            String
  breedId           String                 @unique
  proposalId        String?                @unique
  currentPhaseId    String?                @unique
  status            BreedCampaignStatus
  startedAt         DateTime               @default(now())
  completedAt       DateTime?
  phases            CampaignPhaseDef[]     @relation("CampaignPhases")
  currentPhase      CampaignPhaseDef?      @relation("CurrentPhase", fields: [currentPhaseId], references: [id])
  contributions     CampaignContribution[]
  rewardTiers       CampaignRewardTier[]
  rewardRecords     CampaignRewardRecord[]
  foundationAnimals FoundationAnimal[]
  proposal          BreedProposal?         @relation(fields: [proposalId], references: [id])
  breed             Breed                  @relation(fields: [breedId], references: [id])
  game              Game                   @relation(fields: [gameId], references: [id])
}

model CampaignPhaseDef {
  id                   String                 @id @default(cuid())
  campaignId           String
  name                 String
  lore                 String?
  phaseType            CampaignPhaseType
  triggerConditionType PhaseTriggerType
  phaseIndex           Int
  startsAt             DateTime?
  endsAt               DateTime?
  contributions        CampaignContribution[]
  competitions         Competition[]
  activeCampaign       BreedCampaign?         @relation("CurrentPhase")
  campaign             BreedCampaign          @relation("CampaignPhases", fields: [campaignId], references: [id])

  @@unique([campaignId, phaseIndex])
}

model CampaignContribution {
  id                  String           @id @default(cuid())
  campaignId          String
  phaseDefId          String
  contributorPlayerId String
  animalId            String
  conformationScore   Float
  submittedAt         DateTime         @default(now())
  animal              Animal           @relation(fields: [animalId], references: [id])
  contributorPlayer   PlayerAccount    @relation(fields: [contributorPlayerId], references: [id])
  phaseDef            CampaignPhaseDef @relation(fields: [phaseDefId], references: [id])
  campaign            BreedCampaign    @relation(fields: [campaignId], references: [id])
}

model FoundationAnimal {
  id           String        @id @default(cuid())
  campaignId   String
  breedId      String
  animalId     String
  registeredAt DateTime      @default(now())
  animal       Animal        @relation(fields: [animalId], references: [id])
  breed        Breed         @relation(fields: [breedId], references: [id])
  campaign     BreedCampaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, animalId])
}

model AnimalTemplate {
  id                String                   @id @default(cuid())
  gameId            String
  breedId           String
  statMode          AnimalStatMode
  statFloor         Float?
  healthClear       Boolean                  @default(false)
  personalityMode   PersonalityMode
  personalityMin    Float?
  personalityMax    Float?
  alleleQualityBias Float?
  genotype          AnimalTemplateGenotype[]
  rewardTiers       CampaignRewardTier[]
  breed             Breed                    @relation(fields: [breedId], references: [id])
  game              Game                     @relation(fields: [gameId], references: [id])
}

model AnimalTemplateGenotype {
  id          String         @id @default(cuid())
  templateId  String
  locusId     String
  alleleOneId String
  alleleTwoId String
  alleleTwo   Allele         @relation("TemplateAlleleTwo", fields: [alleleTwoId], references: [id])
  alleleOne   Allele         @relation("TemplateAlleleOne", fields: [alleleOneId], references: [id])
  locus       Locus          @relation(fields: [locusId], references: [id])
  template    AnimalTemplate @relation(fields: [templateId], references: [id])

  @@unique([templateId, locusId])
}

model CampaignRewardTier {
  id                   String                       @id @default(cuid())
  campaignId           String
  tierName             String
  tierIndex            Int
  minRank              Int
  maxRank              Int?
  animalTemplateId     String?
  breedingSlotsAwarded Int                          @default(0)
  currencyRewards      CampaignRewardTierCurrency[]
  itemRewards          CampaignRewardTierItem[]
  rewardRecords        CampaignRewardRecord[]
  animalTemplate       AnimalTemplate?              @relation(fields: [animalTemplateId], references: [id])
  campaign             BreedCampaign                @relation(fields: [campaignId], references: [id])
}

model CampaignRewardTierCurrency {
  id            String             @id @default(cuid())
  tierId        String
  currencyDefId String
  amount        Int
  currencyDef   CurrencyDef        @relation(fields: [currencyDefId], references: [id])
  tier          CampaignRewardTier @relation(fields: [tierId], references: [id])

  @@unique([tierId, currencyDefId])
}

model CampaignRewardTierItem {
  id        String             @id @default(cuid())
  tierId    String
  itemDefId String
  quantity  Int
  itemDef   ItemDef            @relation(fields: [itemDefId], references: [id])
  tier      CampaignRewardTier @relation(fields: [tierId], references: [id])

  @@unique([tierId, itemDefId])
}

model CampaignRewardRecord {
  id                String               @id @default(cuid())
  campaignId        String
  tierId            String
  recipientPlayerId String
  status            CampaignRewardStatus @default(PENDING)
  distributedAt     DateTime?
  recipientPlayer   PlayerAccount        @relation(fields: [recipientPlayerId], references: [id])
  tier              CampaignRewardTier   @relation(fields: [tierId], references: [id])
  campaign          BreedCampaign        @relation(fields: [campaignId], references: [id])
}

model BreedDqTrait {
  id         String @id @default(cuid())
  breedId    String
  locusId    String
  expression String
  locus      Locus  @relation(fields: [locusId], references: [id])
  breed      Breed  @relation(fields: [breedId], references: [id])

  @@unique([breedId, locusId, expression])
}
