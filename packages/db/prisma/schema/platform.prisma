model Game {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String                  @unique
  playerAccounts         PlayerAccount[]
  subscriptionTiers      SubscriptionTier[]
  staffRoles             StaffRole[]
  supportTickets         SupportTicket[]
  bugReports             BugReport[]
  adminActionLogs        AdminActionLog[]
  gameConfig             GameConfig?
  species                Species[]
  breeds                 Breed[]
  lifeStageDefs          LifeStageDef[]
  statDefs               StatDef[]
  animals                Animal[]
  gameInnateMax          GameInnateMax?
  locusDefs              Locus[]
  geneticPanels          GeneticPanelDef[]
  careActionDefs         CareActionDef[]
  longTermCareActionDefs LongTermCareActionDef[]
  healthConditionDefs    HealthConditionDef[]
  healthCertificateDefs  HealthCertificateDef[]
  trainingActionDefs     TrainingActionDef[]
  intensityTierDefs      IntensityTierDef[]
  stageActivityDefs      StageActivityDef[]
  titleDefs              TitleDef[]
  clinics                Clinic[]
  breedingRecords        BreedingRecord[]
  breedingListings       BreedingListing[]
  geneticMaterials       GeneticMaterial[]
  disciplineDefs         DisciplineDef[]
  compTierDefs           CompetitionTierDef[]
  venues                 Venue[]
  competitions           Competition[]
  seasons                Season[]
  recordDefs             RecordDef[]
  directoryFilterDefs    DirectoryFilterDef[]
  currencyDefs           CurrencyDef[]
  transactions           Transaction[]
  itemDefs               ItemDef[]
  storeListings          StoreListing[]
  vetServiceDefs         VetServiceDef[]
  bundles                Bundle[]
  shopBreedConfigs       GameShopBreedConfig[]
  shopAnimals            GameShopAnimal[]
  marketplaceListings    MarketplaceListing[]
  currencyExchangeOrders CurrencyExchangeOrder[]
  escrows                Escrow[]
  gifts                  Gift[]
  raffles                Raffle[]
  playerStores           PlayerStore[]
  jobListings            JobListing[]
  jobContracts           JobContract[]
  breedProposals         BreedProposal[]
  breedCampaigns         BreedCampaign[]
  animalTemplates        AnimalTemplate[]
  groups                 Group[]
  groupPrestigeTierDefs  GroupPrestigeTierDef[]
  friendships            Friendship[]
  friendRequests         FriendRequest[]
  blockedPlayers         BlockedPlayer[]
  follows                Follow[]
  notificationTopicDefs  NotificationTopicDef[]
  notifications          Notification[]
  chatChannels           ChatChannel[]
  directMessages         DirectMessage[]
  forumSections          ForumSection[]
  userReports            UserReport[]
  tutorialStepDefs       TutorialStepDef[]
  achievementDefs        AchievementDef[]
  nightlyUpdateLogs      NightlyUpdateLog[]
  personalityTraitDefs   PersonalityTraitDef[]
  conformationSections   ConformationSection[]
  isActive               Boolean                 @default(false)
  createdAt              DateTime                @default(now())
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  stripeCustomerId      String?                @unique
  emailVerified         Boolean                @default(false)
  name                  String?
  sessions              Session[]
  oauthAccounts         Account[]
  playerAccounts        PlayerAccount[]
  purchaseRecords       PurchaseRecord[]
  staffRoles            StaffRole[]
  banRecords            BanRecord[]            @relation("BannedUser")
  issuedBans            BanRecord[]            @relation("BanIssuedBy")
  userIpLogs            UserIpLog[]
  adminActionLogs       AdminActionLog[]
  supportTicketMessages SupportTicketMessage[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  user                  User      @relation(fields: [userId], references: [id])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PlayerAccount {
  id                         String                     @id @default(cuid())
  userId                     String
  gameId                     String
  username                   String
  avatar                     String?
  playerSubscriptions        PlayerSubscription[]
  supportTickets             SupportTicket[]
  bugReports                 BugReport[]
  bugReportUpvotes           BugReportUpvote[]
  bugReportComments          BugReportComment[]
  animalsOwned               Animal[]                   @relation("AnimalOwner")
  animalsBred                Animal[]                   @relation("AnimalBreeder")
  playerBrand                PlayerBrand?
  foundedBreeds              Breed[]                    @relation("BreedFounder")
  performedCareLogs          CareLog[]                  @relation("CarePerformedBy")
  vetVisitLogs               VetVisitLog[]
  trainingLogsPerformed      TrainingLog[]
  hostedClinics              Clinic[]
  clinicEntries              ClinicEntry[]
  stageActivityLogsPerformed StageActivityLog[]
  breedingListings           BreedingListing[]
  purchasedBreedingSlots     BreedingSlot[]
  ownedGeneticMaterials      GeneticMaterial[]
  competitionEntries         CompetitionEntry[]
  seasonRankings             SeasonRanking[]
  recordEntries              RecordEntry[]
  playerBalances             PlayerBalance[]
  outgoingTransactions       Transaction[]              @relation("TxnFrom")
  incomingTransactions       Transaction[]              @relation("TxnTo")
  actingTransactions         Transaction[]              @relation("ActingPlayer")
  playerInventory            PlayerInventory[]
  playerCapacity             PlayerCapacity?
  subContainers              SubContainer[]
  appliedItems               AnimalAppliedItem[]
  marketplaceListings        MarketplaceListing[]
  marketplaceOffers          MarketplaceOffer[]
  currencyExchangeOrders     CurrencyExchangeOrder[]
  escrowsFrom                Escrow[]                   @relation("EscrowFrom")
  escrowsTo                  Escrow[]                   @relation("EscrowTo")
  giftsFrom                  Gift[]                     @relation("GiftFrom")
  giftsTo                    Gift[]                     @relation("GiftTo")
  raffleEntries              RaffleEntry[]
  raffleItemSubmissions      RaffleItemSubmission[]
  raffleWins                 RaffleWinner[]
  hostedRaffles              Raffle[]
  groupMemberships           GroupMember[]              @relation("GroupMemberAccount")
  groupInvites               GroupMember[]              @relation("GroupInvitedBy")
  foundedGroups              Group[]
  groupAnimalsAdded          GroupAnimal[]
  groupActivityLogs          GroupActivityLog[]
  playerStore                PlayerStore?
  jobListings                JobListing[]
  jobApplications            JobApplication[]
  breedProposals             BreedProposal[]
  proposalVotes              BreedProposalVote[]
  campaignContributions      CampaignContribution[]
  campaignRewards            CampaignRewardRecord[]
  jobContractsAsHirer        JobContract[]              @relation("HirerPlayer")
  jobContractsAsWorker       JobContract[]              @relation("WorkerPlayer")
  jobRatingsGiven            JobRating[]                @relation("RaterPlayer")
  jobRatingsReceived         JobRating[]                @relation("RateePlayer")
  friendshipsAsPlayerOne     Friendship[]               @relation("PlayerOne")
  friendshipsAsPlayerTwo     Friendship[]               @relation("PlayerTwo")
  sentFriendRequests         FriendRequest[]            @relation("FriendRequestSender")
  receivedFriendRequests     FriendRequest[]            @relation("FriendRequestRecipient")
  blocksMade                 BlockedPlayer[]            @relation("BlockerPlayer")
  blocksReceived             BlockedPlayer[]            @relation("BlockedPlayer")
  following                  Follow[]                   @relation("FollowerPlayer")
  followers                  Follow[]                   @relation("FollowedPlayer")
  notificationSettings       NotificationSetting[]
  notifications              Notification[]
  createdChatChannels        ChatChannel[]
  dmConversationsAsPlayerOne DirectMessage[]            @relation("DMPlayerOne")
  dmConversationsAsPlayerTwo DirectMessage[]            @relation("DMPlayerTwo")
  chatMessages               ChatMessage[]
  messageReadStatuses        MessageReadStatus[]
  forumThreadsAuthored       ForumThread[]
  forumPostsAuthored         ForumPost[]
  forumThreadFollows         ForumThreadFollow[]
  pinnedMessages             PinnedMessage[]
  submittedReports           UserReport[]               @relation("ReporterPlayer")
  reportsAgainstMe           UserReport[]               @relation("ReportedPlayer")
  reviewedReports            UserReport[]               @relation("ReviewingPlayer")
  profile                    PlayerProfile?
  seniority                  PlayerSeniority?
  reputation                 PlayerReputation?
  tutorialProgress           TutorialProgress[]
  achievements               PlayerAchievement[]
  profileVisibilitySettings  ProfileVisibilitySetting[]
  game                       Game                       @relation(fields: [gameId], references: [id])
  user                       User                       @relation(fields: [userId], references: [id])
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt

  @@unique([userId, gameId])
}

model SubscriptionTier {
  id                  String               @id @default(cuid())
  name                String
  cost                Int
  gameId              String
  hasGeneReveal       Boolean              @default(false)
  hasPlayerStore      Boolean              @default(false)
  game                Game                 @relation(fields: [gameId], references: [id])
  playerSubscriptions PlayerSubscription[]
  isActive            Boolean              @default(true)
}

model PlayerSubscription {
  id                 String           @id @default(cuid())
  playerAccountId    String
  subscriptionTierId String
  playerAccount      PlayerAccount    @relation(fields: [playerAccountId], references: [id])
  subscriptionTier   SubscriptionTier @relation(fields: [subscriptionTierId], references: [id])
  startedAt          DateTime         @default(now())
  expiresAt          DateTime
  pausedAt           DateTime?
  resumesAt          DateTime?
  isActive           Boolean          @default(true)
}

model PurchaseRecord {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id])
  amount                Decimal
  currency              String
  description           String
  stripePaymentIntentId String?
  createdAt             DateTime @default(now())
}

enum StaffRoleType {
  OWNER
  ADMIN
  MODERATOR
}

model StaffRole {
  id        String        @id @default(cuid())
  userId    String
  gameId    String?
  user      User          @relation(fields: [userId], references: [id])
  game      Game?         @relation(fields: [gameId], references: [id])
  role      StaffRoleType
  createdAt DateTime      @default(now())
}

model BanRecord {
  id             String    @id @default(cuid())
  userId         String
  reason         String
  bannedAt       DateTime  @default(now())
  expiresAt      DateTime?
  bannedByUserId String
  user           User      @relation("BannedUser", fields: [userId], references: [id])
  bannedBy       User      @relation("BanIssuedBy", fields: [bannedByUserId], references: [id])
}

model IpBan {
  id        String    @id @default(cuid())
  ipAddress String    @unique
  reason    String
  bannedAt  DateTime  @default(now())
  expiresAt DateTime?
}

model UserIpLog {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String
  user      User     @relation(fields: [userId], references: [id])
  seenAt    DateTime @default(now())
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SupportTicket {
  id              String                 @id @default(cuid())
  playerAccountId String
  gameId          String
  jobContractId   String?
  subject         String
  body            String
  status          SupportTicketStatus
  messages        SupportTicketMessage[]
  playerAccount   PlayerAccount          @relation(fields: [playerAccountId], references: [id])
  jobContract     JobContract?           @relation(fields: [jobContractId], references: [id])
  game            Game                   @relation(fields: [gameId], references: [id])
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}

model SupportTicketMessage {
  id        String        @id @default(cuid())
  ticketId  String
  authorId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  author    User          @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime      @default(now())
}

enum BugSeverity {
  MINOR
  MAJOR
  GAME_BREAKING
}

enum BugCategory {
  ART
  TEXT
  UI
  MECHANIC
}

enum BugStatus {
  OPEN
  CONFIRMED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model BugReport {
  id        String             @id @default(cuid())
  gameId    String
  authorId  String
  title     String
  body      String
  severity  BugSeverity
  category  BugCategory
  isExploit Boolean            @default(false)
  status    BugStatus
  upvotes   BugReportUpvote[]
  comments  BugReportComment[]
  game      Game               @relation(fields: [gameId], references: [id])
  author    PlayerAccount      @relation(fields: [authorId], references: [id])
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model BugReportUpvote {
  id              String        @id @default(cuid())
  bugReportId     String
  playerAccountId String
  bugReport       BugReport     @relation(fields: [bugReportId], references: [id])
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])
  createdAt       DateTime      @default(now())

  @@unique([bugReportId, playerAccountId])
}

model BugReportComment {
  id          String        @id @default(cuid())
  bugReportId String
  authorId    String
  body        String
  author      PlayerAccount @relation(fields: [authorId], references: [id])
  bugReport   BugReport     @relation(fields: [bugReportId], references: [id])
  createdAt   DateTime      @default(now())
}

model AdminActionLog {
  id          String   @id @default(cuid())
  staffUserId String
  gameId      String?
  action      String
  targetType  String
  targetId    String
  user        User     @relation(fields: [staffUserId], references: [id])
  game        Game?    @relation(fields: [gameId], references: [id])
  createdAt   DateTime @default(now())
}

model NightlyUpdateLog {
  id                       String    @id @default(cuid())
  gameId                   String
  startedAt                DateTime  @default(now())
  completedAt              DateTime?
  success                  Boolean   @default(true)
  errorMessage             String?
  animalsAged              Int       @default(0)
  animalDeaths             Int       @default(0)
  lifeStageTransitions     Int       @default(0)
  storeRotationsProcessed  Int       @default(0)
  rafflesDrawn             Int       @default(0)
  jobContractsProcessed    Int       @default(0)
  seasonRewardsDistributed Int       @default(0)
  campaignPhaseTransitions Int       @default(0)
  subscriptionsExpired     Int       @default(0)
  game                     Game      @relation(fields: [gameId], references: [id])
}

model GameConfig {
  id                        String   @id @default(cuid())
  gameId                    String   @unique
  defaultInnateRatio        Float
  trainingCeilingMultiplier Float
  pedigreeDisplayDepth      Int
  predictorDailyLimitFree   Int
  containerLabel            String?
  subContainerLabel         String?
  breedingEnergyCost        Float    @default(0)
  gestationCycles           Int      @default(12)
  moodDecayRate             Float    @default(0)
  conditionDecayRate        Float    @default(0)
  conditionWorkGain         Float    @default(0)
  careScoreDecayRate        Float    @default(0)
  careScoreFloor            Float    @default(0)
  careScoreCeiling          Float    @default(100)
  careScoreRecoveryRate     Float    @default(0)
  immunityDecayRate         Float    @default(0)
  immunityRecoveryRate      Float    @default(0)
  immunityMin               Float    @default(0)
  immunityMax               Float    @default(100)
  energyLowCareThreshold    Float    @default(0)
  energyLowCarePenalty      Float    @default(0)
  cyclesPerYear             Int      @default(12)
  lifeExpectancyBaseline    Int?
  maxLocusTestsPerCycle     Int      @default(2)
  game                      Game     @relation(fields: [gameId], references: [id])
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}
