enum GroupMemberStatus {
  PENDING
  ACTIVE
  BANNED
  LEFT
}

enum PrestigeSource {
  COMPETITION_PLACEMENT
  COMPETITION_HOSTED
  CLINIC_HOSTED
  SEASON_RANKING
}

enum GroupAnimalStatus {
  PENDING_ENTRY
  IN_CONTAINER
  OUT_OF_CONTAINER
}

enum GroupPermission {
  MANAGE_MEMBERS
  MANAGE_ROLES
  ADD_TO_CONTAINER
  REMOVE_FROM_CONTAINER
  VIEW_FINANCES
  MANAGE_FINANCES
  HOST_EVENTS
  MANAGE_ENTRY_REQUIREMENTS
  MANAGE_INVENTORY
  POST_ANNOUNCEMENT
  MANAGE_CHANNELS
}

enum GroupActivityType {
  MEMBER_JOINED
  MEMBER_LEFT
  MEMBER_INVITED
  MEMBER_ROLE_CHANGED
  MEMBER_BANNED
  ANIMAL_GROUP_JOINED
  ANIMAL_ENTERED_CONTAINER
  ANIMAL_LEFT_CONTAINER
  ANIMAL_SOLD
  FINANCE_DEPOSIT
  FINANCE_WITHDRAWAL
  INVENTORY_ADDED
  INVENTORY_REMOVED
  ANNOUNCEMENT_POSTED
  PRESTIGE_EARNED
}

enum GroupChannelType {
  ANNOUNCEMENT
  GENERAL
  ROLE_RESTRICTED
}

enum GroupRequirementType {
  CARE_SCORE
  COMPETITION_TIER
  NO_ACTIVE_CONDITIONS
  GENETIC_PANEL_TESTED
  NO_ACTIVE_RESTRICTIONS
  STAT_VALUE
  CONFORMATION_SCORE
  PHENOTYPE_EXPRESSION
  DISCIPLINE_COMPETITION_TIER
  INBREEDING_COEFFICIENT
}

enum GroupSaleRule {
  REQUIRE_APPROVAL
  MIN_OFFER_AMOUNT
  NO_SALE_DURING_SEASON
  FIRST_REFUSAL
}

enum GroupSpendingCategory {
  BREEDING
  TRAINING
  COMPETITION
  VET
  ITEM_USE
  CARE
}

model Group {
  id                   String                    @id @default(cuid())
  gameId               String
  name                 String
  tag                  String
  description          String?
  image                String?
  breedId              String?
  isOpen               Boolean                   @default(true)
  maxMembers           Int?
  isActive             Boolean                   @default(true)
  disbandedAt          DateTime?
  foundedByPlayerId    String?
  members              GroupMember[]
  roles                GroupRole[]
  groupAnimals         GroupAnimal[]
  spendingRules        GroupAnimalSpendingRule[]
  saleProtectionRules  GroupSaleProtectionRule[]
  entryRequirements    GroupEntryRequirement[]
  finance              GroupFinance[]
  inventory            GroupInventory[]
  prestige             GroupPrestige?
  prestigeLogs         GroupPrestigeLog[]
  channels             GroupChannel[]
  activityLogs         GroupActivityLog[]
  clinics              Clinic[]
  raffles              Raffle[]
  seasonRankings       SeasonRanking[]
  recordEntries        RecordEntry[]
  transactionsFrom     Transaction[]             @relation("TxnFromGroup")
  transactionsTo       Transaction[]             @relation("TxnToGroup")
  geneticMaterials     GeneticMaterial[]
  followers            Follow[]
  forumThreadsAuthored ForumThread[]
  forumPostsAuthored   ForumPost[]
  userReports          UserReport[]
  createdAt            DateTime                  @default(now())
  foundedBy            PlayerAccount?            @relation(fields: [foundedByPlayerId], references: [id])
  breed                Breed?                    @relation(fields: [breedId], references: [id])
  game                 Game                      @relation(fields: [gameId], references: [id])
  disciplineDef        DisciplineDef?            @relation(fields: [disciplineDefId], references: [id])
  disciplineDefId      String?
}

model GroupMember {
  id                String            @id @default(cuid())
  groupId           String
  playerAccountId   String
  groupRoleId       String
  status            GroupMemberStatus
  invitedByPlayerId String?
  createdAt         DateTime          @default(now())
  joinedAt          DateTime?
  leftAt            DateTime?
  groupRole         GroupRole         @relation(fields: [groupRoleId], references: [id])
  invitedByPlayer   PlayerAccount?    @relation("GroupInvitedBy", fields: [invitedByPlayerId], references: [id])
  playerAccount     PlayerAccount     @relation("GroupMemberAccount", fields: [playerAccountId], references: [id])
  group             Group             @relation(fields: [groupId], references: [id])

  @@unique([groupId, playerAccountId])
}

model GroupRole {
  id                  String                    @id @default(cuid())
  groupId             String
  name                String
  displayOrder        Int?
  isDefault           Boolean                   @default(false)
  isOwner             Boolean                   @default(false)
  permissions         GroupRolePermission[]
  members             GroupMember[]
  spendingRules       GroupAnimalSpendingRule[]
  saleProtectionRules GroupSaleProtectionRule[]
  restrictedChannels  GroupChannel[]
  group               Group                     @relation(fields: [groupId], references: [id])

  @@unique([groupId, name])
}

model GroupRolePermission {
  id          String          @id @default(cuid())
  groupRoleId String
  permission  GroupPermission
  groupRole   GroupRole       @relation(fields: [groupRoleId], references: [id])

  @@unique([groupRoleId, permission])
}

model GroupAnimal {
  id              String            @id @default(cuid())
  groupId         String
  animalId        String
  status          GroupAnimalStatus @default(PENDING_ENTRY)
  addedAt         DateTime          @default(now())
  addedByPlayerId String?
  leftContainerAt DateTime?
  addedByPlayer   PlayerAccount?    @relation(fields: [addedByPlayerId], references: [id])
  animal          Animal            @relation(fields: [animalId], references: [id])
  group           Group             @relation(fields: [groupId], references: [id])

  @@unique([groupId, animalId])
}

model GroupAnimalSpendingRule {
  id                 String                @id @default(cuid())
  groupId            String
  groupRoleId        String
  spendingCategory   GroupSpendingCategory
  requiresApproval   Boolean               @default(true)
  maxAmountPerAnimal Int?
  groupRole          GroupRole             @relation(fields: [groupRoleId], references: [id])
  group              Group                 @relation(fields: [groupId], references: [id])

  @@unique([groupId, groupRoleId, spendingCategory])
}

model GroupSaleProtectionRule {
  id                     String        @id @default(cuid())
  groupId                String
  ruleType               GroupSaleRule
  minOfferAmount         Int?
  requiredApprovalRoleId String?
  conditionStatDefId     String?
  conditionBreedId       String?
  conditionMinValue      Float?
  conditionMaxValue      Float?
  requiredApprovalRole   GroupRole?    @relation(fields: [requiredApprovalRoleId], references: [id])
  conditionStatDef       StatDef?      @relation(fields: [conditionStatDefId], references: [id])
  conditionBreed         Breed?        @relation(fields: [conditionBreedId], references: [id])
  group                  Group         @relation(fields: [groupId], references: [id])
}

model GroupEntryRequirement {
  id                   String               @id @default(cuid())
  groupId              String
  requirementType      GroupRequirementType
  minValue             Float?
  maxValue             Float?
  statDefId            String?
  breedId              String?
  healthConditionDefId String?
  geneticPanelDefId    String?
  disciplineDefId      String?
  locusId              String?
  requiredPhenotype    String?
  locus                Locus?               @relation(fields: [locusId], references: [id])
  disciplineDef        DisciplineDef?       @relation(fields: [disciplineDefId], references: [id])
  geneticPanelDef      GeneticPanelDef?     @relation(fields: [geneticPanelDefId], references: [id])
  healthConditionDef   HealthConditionDef?  @relation(fields: [healthConditionDefId], references: [id])
  breed                Breed?               @relation(fields: [breedId], references: [id])
  statDef              StatDef?             @relation(fields: [statDefId], references: [id])
  group                Group                @relation(fields: [groupId], references: [id])
}

model GroupFinance {
  id            String      @id @default(cuid())
  groupId       String
  currencyDefId String
  balance       Int         @default(0)
  currencyDef   CurrencyDef @relation(fields: [currencyDefId], references: [id])
  group         Group       @relation(fields: [groupId], references: [id])

  @@unique([groupId, currencyDefId])
}

model GroupInventory {
  id        String  @id @default(cuid())
  groupId   String
  itemDefId String
  quantity  Int     @default(0)
  itemDef   ItemDef @relation(fields: [itemDefId], references: [id])
  group     Group   @relation(fields: [groupId], references: [id])

  @@unique([groupId, itemDefId])
}

model GroupPrestige {
  id        String                @id @default(cuid())
  groupId   String                @unique
  score     Float                 @default(0)
  tierDefId String?
  tierDef   GroupPrestigeTierDef? @relation(fields: [tierDefId], references: [id])
  group     Group                 @relation(fields: [groupId], references: [id])
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

model GroupPrestigeTierDef {
  id                           String          @id @default(cuid())
  gameId                       String
  name                         String
  tierIndex                    Int
  minScore                     Float
  maxMembers                   Int
  maxGroupAnimals              Int
  maxHostedShowsPerDay         Int?
  prestigeCurrencyRewardPerDay Float           @default(0)
  vetDiscountPercent           Float           @default(0)
  prestigeLevels               GroupPrestige[]
  game                         Game            @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
  @@unique([gameId, tierIndex])
}

model GroupPrestigeLog {
  id        String   @id @default(cuid())
  groupId   String
  source    PrestigeSource
  amount    Float
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id])
}

model GroupChannel {
  id             String           @id @default(cuid())
  groupId        String
  chatChannelId  String?          @unique
  name           String
  channelType    GroupChannelType
  requiredRoleId String?
  isDefault      Boolean          @default(false)
  displayOrder   Int?
  requiredRole   GroupRole?       @relation(fields: [requiredRoleId], references: [id])
  chatChannel    ChatChannel?     @relation(fields: [chatChannelId], references: [id])
  group          Group            @relation(fields: [groupId], references: [id])

  @@unique([groupId, name])
}

model GroupActivityLog {
  id              String            @id @default(cuid())
  groupId         String
  playerAccountId String?
  activityType    GroupActivityType
  targetType      String?
  targetId        String?
  metadata        Json?
  createdAt       DateTime          @default(now())
  playerAccount   PlayerAccount?    @relation(fields: [playerAccountId], references: [id])
  group           Group             @relation(fields: [groupId], references: [id])
}
