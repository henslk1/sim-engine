enum ChannelType {
  GLOBAL 
  GROUP 
  DM
}

enum ForumAuthorType {
  PLAYER 
  GROUP
}

enum ReportType {
  PLAYER 
  ANIMAL
  GROUP 
  FORUM_POST
  FORUM_THREAD
  CHAT_MESSAGE
  DIRECT_MESSAGE
  MARKETPLACE_LISTING
}

enum ReportStatus {
  PENDING 
  REVIEWED 
  DISMISSED
}

model Friendship {
  id          String        @id @default(cuid())
  gameId      String
  playerOneId String
  playerTwoId String
  createdAt   DateTime      @default(now())
  playerTwo   PlayerAccount @relation("PlayerTwo", fields: [playerTwoId], references: [id])
  playerOne   PlayerAccount @relation("PlayerOne", fields: [playerOneId], references: [id])
  game        Game          @relation(fields: [gameId], references: [id])

  @@unique([gameId, playerOneId, playerTwoId])
}

model FriendRequest {
  id                String        @id @default(cuid())
  gameId            String
  senderPlayerId    String
  recipientPlayerId String
  createdAt         DateTime      @default(now())
  recipientPlayer   PlayerAccount @relation("FriendRequestRecipient", fields: [recipientPlayerId], references: [id])
  senderPlayer      PlayerAccount @relation("FriendRequestSender", fields: [senderPlayerId], references: [id])
  game              Game          @relation(fields: [gameId], references: [id])

  @@unique([gameId, senderPlayerId, recipientPlayerId])
}

model BlockedPlayer {
  id                String        @id @default(cuid())
  gameId            String
  blockedPlayerId   String
  blockerPlayerId   String
  blockerPlayer     PlayerAccount @relation("BlockerPlayer", fields: [blockedByPlayerId], references: [id])
  blockedPlayer     PlayerAccount @relation("BlockedPlayer", fields: [blockedPlayerId], references: [id])
  game              Game          @relation(fields: [gameId], references: [id])

  @@unique([gameId, blockedByPlayerId, blockerPlayerId])
}

model Follow {
  id               String         @id @default(cuid())
  gameId           String
  followerPlayerId String
  followedPlayerId String?
  followedGroupId  String?
  followedAnimalId String?
  followedAnimal   Animal?        @relation(fields: [followedAnimalId], references: [id])
  followedGroup    Group?         @relation(fields: [followedGroupId], references: [id])
  followedPlayer   PlayerAccount? @relation("FollowedPlayer", fields: [followedPlayerId], references: [id])
  followerPlayer   PlayerAccount  @relation("FollowerPlayer", fields: [followerPlayerId], references: [id])
  game             Game           @relation(fields: [gameId], references: [id])
}

model NotificationTopicDef {
  id                     String @id @default(cuid())
  gameId               String
  topicKey             String
  name                 String
  isDefaultEnabled     Boolean  @default(true)
  notificationSettings NotificationSetting[]
  notifications        Notification[]
  game                 Game     @relation(fields: [gameId], references: [id])
  
  @@unique([gameId, topicKey])
}

model NotificationSetting {
  id              String               @id @default(cuid())
  playerAccountId String
  topicDefId      String
  isEnabled       Boolean              @default(true)
  topicDef        NotificationTopicDef @relation(fields: [topicDefId], references: [id])
  playerAccount   PlayerAccount        @relation(fields: [playerAccountId], references: [id])

  @@unique([playerAccountId, topicDefId])
}

model Notification {
  id                String               @id @default(cuid())
  gameId            String
  topicDefId        String?
  recipientPlayerId String
  content           String
  link              String?
  isRead            Boolean              @default(false)
  createdAt         DateTime             @default(now())
  recipientPlayer   PlayerAccount        @relation(fields: [recipientPlayerId], references: [id])
  topicDef          NotificationTopicDef @relation(fields: [topicDefId], references: [id])
  game              Game                 @relation(fields: [gameId], references: [id])
}

model ChatChannel {
  id                String         @id @default(cuid())
  gameId            String
  channelType       ChannelType
  name              String?
  description       String?
  isArchived        Boolean        @default(false)
  createdAt         DateTime       @default(now())
  createdByPlayerId String?
  messages          ChatMessage[]
  directMessage     DirectMessage?
  readStatuses      MessageReadStatus[]
  createdByPlayer   PlayerAccount? @relation(fields: [createdByPlayerId], references: [id])
  game              Game           @relation(fields: [gameId], references: [id])
}

model DirectMessage {
  id            String        @id @default(cuid())
  gameId        String
  chatChannelId String
  playerOneId   String
  playerTwoId   String
  playerTwo     PlayerAccount @relation("DMPlayerTwo", fields: [playerTwoId], references: [id])
  playerOne     PlayerAccount @relation("DMPlayerOne", fields: [playerOneId], references: [id])
  chatChannel   ChatChannel   @relation(fields: [chatChannelId], references: [id])
  game          Game          @relation(fields: [gameId], references: [id])
  
  @@unique([playerOneId, playerTwoId])
}

model ChatMessage {
  id                 String        @id @default(cuid())
  channelId          String
  authorPlayerId     String
  content            String
  readStatusPointers MessageReadStatus[]
  pinnedMessages     PinnedMessage[]
  createdAt          DateTime      @default(now())
  editedAt           DateTime?
  isDeleted          Boolean       @default(false)
  authorPlayer       PlayerAccount @relation(fields: [authorPlayerId], references: [id])
  channel            ChatChannel   @relation(fields: [channelId], references: [id])
}

model MessageReadStatus {
  id                String        @id @default(cuid())
  playerAccountId   String
  chatChannelId     String
  lastReadMessageId String
  lastReadAt        DateTime?
  lastReadMessage   ChatMessage   @relation(fields: [lastReadMessageId], references: [id])
  chatChannel       ChatChannel   @relation(fields: [chatChannelId], references: [id])
  playerAccount     PlayerAccount @relation(fields: [playerAccountId], references: [id])

  @@unique([playerAccountId, chatChannelId])
}

model ForumSection {
  id           String  @id @default(cuid())
  gameId       String
  name         String
  description  String?
  threads      ForumThread[]
  displayOrder Int?
  isArchived   Boolean @default(false)
  game         Game    @relation(fields: [gameId], references: [id])
}

model ForumThread {
  id               String         @id @default(cuid())
  sectionId        String
  authorPlayerId   String?
  authorGroupId    String?
  authorType       ForumAuthorType
  title            String
  isLocked         Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  lastPostAt       DateTime
  posts            ForumPost[]
  followingPlayers ForumThreadFollow[]
  pinnedPosts      PinnedMessage[]
  authorGroup      Group?         @relation(fields: [authorGroupId], references: [id])
  authorPlayer     PlayerAccount? @relation(fields: [authorPlayerId], references: [id])
  section          ForumSection   @relation(fields: [sectionId], references: [id])
}

model ForumPost {
  id             String         @id @default(cuid())
  threadId       String
  authorPlayerId String
  authorGroupId  String 
  authorType     ForumAuthorType
  content        String
  isDeleted      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  edotedAt       DateTime?
  authorGroup    Group?         @relation(fields: [authorGroupId], references: [id])
  authorPlayer   PlayerAccount? @relation(fields: [authorPlayerId], references: [id])
  thread         ForumThread    @relation(fields: [threadId], references: [id])
}

model ForumThreadFollow {
  id              String        @id @default(cuid())
  threadId        String
  thread          ForumThread   @relation(fields: [threadId], references: [id])
  playerAccountId String
  followedAt      DateTime      @default(now())
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])

  @@unique([threadId, playerAccountId])
}

model PinnedMessage {
  id               String        @id @default(cuid())
  pinnedByPlayerId String
  chatMessageId    String
  forumThreadId    String
  pinnedAt         DateTime      @default(now())
  forumThread      ForumThread   @relation(fields: [forumThreadId], references: [id])
  chatMessage      ChatMessage   @relation(fields: [chatMessageId], references: [id])
  pinnedByPlayer   PlayerAccount @relation(fields: [pinnedByPlayerId], references: [id])
}

model UserReport {
  id                           String              @id @default(cuid())
  gameId                       String
  reporterPlayerId             String
  reportType                   ReportType
  reason                       String
  status                       ReportStatus        @default(PENDING)
  reportedPlayerId             String?
  reportedAnimalId             String?
  reportedGroupId              String
  reportedForumPostId          String?
  reportedForumThreadId        String?
  reportedChatMessageId        String?
  reportedMarketplaceListingId String?
  reviedByPlayerId             String?
  reviewedAt                   DateTime?
  adminNote                    String?
  createdAt                    DateTime            @default(now())
  reportedMarketplaceListing   MarketplaceListing? @relation(fields: [reportedMarketplaceListingId], references: [id])
  reportedChatMessage          ChatMessage?        @relation(fields: [reportedChatMessageId], references: [id])
  reportedForumThread          ForumThread?        @relation(fields: [reportedForumThreadId], references: [id])
  reportedForumPost            ForumPost?          @relation(fields: [reportedForumPostId], references: [id])
  reportedGroup                Group?              @relation(fields: [reportedGroupId], references: [id])
  reportedAnimal               Animal?             @relation(fields: [reportedAnimalId], references: [id])
  reportedPlayer               PlayerAccount?      @relation("ReportedPlayer", fields: [reportedPlayerId], references: [id])
  reporterPlayer               PlayerAccount       @relation("ReporterPlayer", fields: [reporterPlayerId], references: [id])
  reviedByPlayer               PlayerAccount?      @relation("ReviewingPlayer", fields: [reviedByPlayerId], references: [id])

  game                         Game                @relation(fields: [gameId], references: [id])
}