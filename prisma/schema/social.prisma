enum ChannelType {
  GLOBAL 
  GROUP 
  DM
}

enum ForumAuthorType {
  PLAYER 
  GROUP
}

enum ReportType {
  PLAYER 
  ANIMAL
  GROUP 
  FORUM_POST
  FORUM_THREAD
  CHAT_MESSAGE
  DIRECT_MESSAGE
  MARKETPLACE_LISTING
}

enum ReportStatus {
  PENDING 
  REVIEWED 
  DISMISSED
}

model Friendship {
  id          String        @id @default(cuid())
  gameId      String
  playerOneId String
  playerTwoId String
  createdAt   DateTime      @default(now())
  playerTwo   PlayerAccount @relation("PlayerTwo", fields: [playerTwoId], references: [id])
  playerOne   PlayerAccount @relation("PlayerOne", fields: [playerOneId], references: [id])
  game        Game          @relation(fields: [gameId], references: [id])

  @@unique([gameId, playerOneId, playerTwoId])
}

model FriendRequest {
  id                String        @id @default(cuid())
  gameId            String
  senderPlayerId    String
  recipientPlayerId String
  createdAt         DateTime      @default(now())
  recipientPlayer   PlayerAccount @relation("FriendRequestRecipient", fields: [recipientPlayerId], references: [id])
  senderPlayer      PlayerAccount @relation("FriendRequestSender", fields: [senderPlayerId], references: [id])
  game              Game          @relation(fields: [gameId], references: [id])

  @@unique([gameId, senderPlayerId, recipientPlayerId])
}

model BlockedPlayer {
  id                String        @id @default(cuid())
  gameId            String
  blockedPlayerId   String
  blockerPlayerId   String
  blockerPlayer     PlayerAccount @relation("BlockerPlayer", fields: [blockedByPlayerId], references: [id])
  blockedPlayer     PlayerAccount @relation("BlockedPlayer", fields: [blockedPlayerId], references: [id])
  game              Game          @relation(fields: [gameId], references: [id])

  @@unique([gameId, blockedByPlayerId, blockerPlayerId])
}

model Follow {
  id               String         @id @default(cuid())
  gameId           String
  followerPlayerId String
  followedPlayerId String?
  followedGroupId  String?
  followedAnimalId String?
  followedAnimal   Animal?        @relation(fields: [followedAnimalId], references: [id])
  followedGroup    Group?         @relation(fields: [followedGroupId], references: [id])
  followedPlayer   PlayerAccount? @relation("FollowedPlayer", fields: [followedPlayerId], references: [id])
  followerPlayer   PlayerAccount  @relation("FollowerPlayer", fields: [followerPlayerId], references: [id])
  game             Game           @relation(fields: [gameId], references: [id])
}

model NotificationTopicDef {
  id                     String @id @default(cuid())
  gameId               String
  topicKey             String
  name                 String
  isDefaultEnabled     Boolean  @default(true)
  notificationSettings NotificationSetting[]
  notifications        Notification[]
  game                 Game     @relation(fields: [gameId], references: [id])
  
  @@unique([gameId, topicKey])
}

model NotificationSetting {
  id              String               @id @default(cuid())
  playerAccountId String
  topicDefId      String
  isEnabled       Boolean              @default(true)
  topicDef        NotificationTopicDef @relation(fields: [topicDefId], references: [id])
  playerAccount   PlayerAccount        @relation(fields: [playerAccountId], references: [id])

  @@unique([playerAccountId, topicDefId])
}

model Notification {
  id                String               @id @default(cuid())
  gameId            String
  topicDefId        String?
  recipientPlayerId String
  content           String
  link              String?
  isRead            Boolean              @default(false)
  createdAt         DateTime             @default(now())
  recipientPlayer   PlayerAccount        @relation(fields: [recipientPlayerId], references: [id])
  topicDef          NotificationTopicDef @relation(fields: [topicDefId], references: [id])
  game              Game                 @relation(fields: [gameId], references: [id])
}

model ChatChannel {
  id String @id @default(cuid())
}

model DirectMessage {
  id String @id @default(cuid())
}

model ChatMessage {
  id String @id @default(cuid())
}

model MessageReadStatus {
  id String @id @default(cuid())
}

model ForumSection {
  id String @id @default(cuid())
}

model ForumThread {
  id String @id @default(cuid())
}

model ForumPost {
  id String @id @default(cuid())
}

model PinnedMessage {
  id String @id @default(cuid())
}

model UserReport {
  id String @id @default(cuid())
}