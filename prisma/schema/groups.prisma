enum GroupMemberStatus {
  PENDING 
  ACTIVE 
  BANNED
  LEFT
}

enum GroupAnimalStatus {
  PENDING_ENTRY
  IN_CONTAINER
  OUT_OF_CONTAINER 
}
 
enum GroupPermission {
  MANAGE_MEMBERS
  MANAGE_ROLES
  MANAGE_ANIMALS
  VIEW_FINANCES
  MANAGE_FINANCES
  MANAGE_STORE
  HOST_EVENTS
  MANAGE_ENTRY_REQUIREMENTS
  MANAGE_INVENTORY
  POST_ANNOUNCEMENT
  MANAGE_CHANNELS
}

enum GroupActivityType {
  MEMBER_JOINED
  MEMBER_LEFT
  MEMBER_INVITED
  MEMBER_ROLE_CHANGED
  MEMBER_BANNED
  ANIMAL_GROUP_JOINED
  ANIMAL_ENTERED_CONTAINER
  ANIMAL_LEFT_CONTAINER
  ANIMAL_SOLD
  FINANCE_DEPOSIT
  FINANCE_WITHDRAWAL
  INVENTORY_ADDED
  INVENTORY_REMOVED
  ANNOUNCEMENT_POSTED
  PRESTIGE_EARNED
}

enum GroupChannelType {
  ANNOUNCEMENT 
  GENERAL 
  ROLE_RESTRICTED
}

enum GroupRequirementType {
  CARE_SCORE 
  COMPETITION_TIER
  NO_ACTIVE_CONDITIONS
  GENETIC_PANEL_TESTED
  NO_ACTIVE_RESTRICTIONS
  STAT_VALUE
  CONFORMATION_SCORE
  INBREEDING_COEFFICIENT
}

enum GroupSaleRule {
  REQUIRE_APPROVAL
  MIN_OFFER_AMOUNT
  NO_SALE_DURING_SEASON
  FIRST_REFUSAL
}

enum GroupSpendingCategory {
  BREEDING 
  TRAINING 
  COMPETITION
  VET 
  ITEM_USE 
  CARE
}

model Group {
  id String @id @default(cuid())
}

model GroupMember {
  id String @id @default(cuid())
}

model GroupRole {
  id String @id @default(cuid())
}

model GroupRolePermission {
  id String @id @default(cuid())
  groupRoleId String
  permission  GroupPermission
  groupRole GroupRole @relation(fields: [groupRoleId], references: [id])

  @@unique([groupRoleId, permission])
} 

model GroupAnimal {
  id              String            @id @default(cuid())
  groupId         String
  animalId        String
  status          GroupAnimalStatus @default("PENDING_ENTRY")
  addedAt         DateTime          @default(now())
  addedByPlayerId String?
  leftContainerat DateTime?
  addedByPlayer   PlayerAccount?    @relation(fields: [addedByPlayerId], references: [id])
  animal          Animal            @relation(fields: [animalId], references: [id])
  group           Group             @relation(fields: [groupId], references: [id])

  @@unique([groupId, animalId])
}

model GroupAnimalSpendingRule {
  id                String    @id @default(cuid())
  groupId           String
  groupRoleId       String
  spendingCategory  GroupSpendingCategory
  requiresApproval  Boolean   @default(true)
  maxAmountPerCycle Int?
  groupRole         GroupRole @relation(fields: [groupRoleId], references: [id])
  group             Group     @relation(fields: [groupId], references: [id])

  @@unique([groupId, groupRoleId, spendingCategory])
}

model GroupSaleProtectionRule {
  id String @id @default(cuid())
  groupId String
  ruleType GroupSaleProtectionRule
  minOfferAmount Int?
  requiredApprovalRoleId String?
  conditionStatDefId     String?
  conditionBreedId       String?
  conditionMinValue      Float?
  conditionMaxValue      Float?
  requiredApprovalRole   GroupRole? @relation(fields: [requiredApprovalRoleId], references: [id])
  conditionStatDef       StatDef?   @relation(fields: [conditionStatDefId], references: [id])
  conditionBreed         Breed?     @relation(fields: [conditionBreedId], references: [id])
  group Group @relation(fields: [groupId], references: [id])
}

model GroupEntryRequirement {
  id                String           @id @default(cuid())
  groupId           String
  requirementType   GroupRequirementType
  minValue          Float?
  maxValue          Float?
  statDefId         String?
  breedId           String?
  conditionDefId    String?
  geneticPanelDefId String?
  geneticPanelDef   GeneticPanelDef? @relation(fields: [geneticPanelDefId], references: [id])
  conditionDef      ConditionDef?    @relation(fields: [conditionDefId], references: [id])
  breed             Breed?           @relation(fields: [breedId], references: [id])
  statDef           StatDef?         @relation(fields: [statDefId], references: [id])
  group             Group            @relation(fields: [groupId], references: [id])
}

model GroupFinance {
  id            String      @id @default(cuid())
  groupId       String
  currencyDefId String
  balance       Int         @default(0)
  currencyDef   CurrencyDef @relation(fields: [currencyDefId], references: [id])
  group         Group       @relation(fields: [groupId], references: [id])

  @@unique([groupId, currencyDefId])
}

model GroupInventory {
  id        String  @id @default(cuid())
  groupId   String
  itemDefId String
  quantity  Int @default(0)
  itemDef   ItemDef @relation(fields: [itemDefId], references: [id])
  group     Group   @relation(fields: [groupId], references: [id])

  @@unique([groupId, itemDefId])
}

model GroupPrestige {
  id        String               @id @default(cuid())
  groupId   String               @unique
  score     Float                @default(0)
  tierDefId String?
  tierDef   GroupPresigeTierDef? @relation(fields: [tierDefId], references: [id])
  group     Group                @relation(fields: [groupId], references: [id])
}

model GroupPresigeTierDef {
  id                     String @id @default(cuid())
  gameId                 String
  name                   String
  tierIndex              Int
  minScore               Float
  maxMembers             Int
  maxGroupAnimals        Int
  maxHostedShowsPerCycle Int?
  shopStatFloor          Float  @default(0)
  shopAlleleQualityBias  Float  @default(0)
  vetDiscountPercent     Float  @default(0)
  prestigeLevels         GroupPrestige[]
  game                   Game   @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model GroupPrestigeLog {
  id        String   @id @default(cuid())
  groupId   String
  source    String
  amount    Float
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id])
}

model GroupChannel {
  id             String @id @default(cuid())
  groupId        String
  name           String
  channelType    GroupChannelType
  requiredRoleId String?
  isDefault      Boolean
  displayOrder   Int?
  requiredRole   GroupRole?
  group          Group  @relation(fields: [groupId], references: [id])

  @@unique([groupId, name])
}

model GroupActivityLog {
  id              String         @id @default(cuid())
  groupId         String
  playerAccountId String?
  activityType    GroupActivityType
  targetType      String?
  targetId        String?
  metadata        Json?
  createdAt       DateTime       @default(now())
  playerAccount   PlayerAccount? @relation(fields: [playerAccountId], references: [id])
  group           Group          @relation(fields: [groupId], references: [id])
}