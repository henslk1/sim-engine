enum JobListingType {
  HIRER_POST
  WORKER_POST
}

enum JobListingStatus {
  OPEN
  FILLED 
  CLOSED 
  EXPIRED
}

enum JobApplicationStatus {
  PENDING 
  ACCEPTED 
  REJECTED 
  WITHDRAWN
}

enum JobContractStatus {
  ACTIVE 
  CLOSURE_REQUESTED
  PENDING_REVIEW
  COMPLETED 
  SETTLED 
  CANCELLED
}

model JobListing {
  id String @id @default(cuid())
}

model JobApplication {
  id String @id @default(cuid())
}

model JobContract {
  id String @id @default(cuid())
}

model JobContactAnimal {
  id String @id @default(cuid())
}

model JobCompletionRecord {
  id String @id @default(cuid())
}

model JobRating {
  id String @id @default(cuid())
}