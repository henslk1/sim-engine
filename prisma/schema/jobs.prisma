enum JobListingType {
  HIRER_POST
  WORKER_POST
}

enum JobListingStatus {
  OPEN
  FILLED 
  CLOSED 
  EXPIRED
}

enum JobApplicationStatus {
  PENDING 
  ACCEPTED 
  REJECTED 
  WITHDRAWN
}

enum JobContractStatus {
  ACTIVE 
  CLOSURE_REQUESTED
  PENDING_REVIEW
  COMPLETED 
  SETTLED 
  CANCELLED
}

model JobListing {
  id String @id @default(cuid())
  gameId String
  postedByPlayerId String
  listingType      JobListingType
  description      String?
  maxAnimals       Int?
  minAnimals       Int?
  durationDays     Int?
  maxAgingCycles   Int?
  ratePerAnimal    Float?
  currencyDefId    String?
  status           JobListingStatus
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
  permitCare              Boolean        @default(false)  
  permitTraining          Boolean        @default(false)  
  permitBreeding          Boolean        @default(false)      
  permitCompetition       Boolean        @default(false)             
  permitAging             Boolean        @default(false)       
  resourceBaseItems       Boolean        @default(false)
  resourcePremiumItems    Boolean        @default(false) 
  resourceBaseCurrency    Boolean        @default(false)  
  resourcePremiumCurrency Boolean        @default(false)  
  applications            JobApplication[]
  contacts                JobContract[]
  currencyDef CurrencyDef? @relation(fields: [currencyDefId], references: [id])
  postedByPlayer PlayerAccount @relation(fields: [postedByPlayerId], references: [id])
  game Game @relation(fields: [gameId], references: [id])
}

model JobApplication {
  id                    String @id @default(cuid())
  jobListingId          String
  applicantPlayerId     String
  proposedRatePerAnimal Float?
  currencyDefId         String?
  message               String?
  status                JobApplicationStatus  
  contract              JobContract?
  createdAt             DateTime @default(now())
  currencyDef           CurrencyDef? @relation(fields: [currencyDefId], references: [id])
  applicantPlayer       PlayerAccount @relation(fields: [applicantPlayerId], references: [id])
  jobListing            JobListing @relation(fields: [jobListingId], references: [id])
}

model JobContract {
  id                      String         @id @default(cuid())
  gameId                  String
  jobListingId            String
  jobApplicationId        String         @unique
  hirerPlayerId           String
  workerPlayerId          String
  durationDays            Int?
  maxAgingCycles          Int?
  agreedRatePerAnimal     Float          @default(0)
  currencyDefId           String?
  status                   JobContractStatus
  startedAt               DateTime       @default(now())
  endsAt                  DateTime?
  closureRequestedAt      DateTime?
  completedAt             DateTime?
  contractAnimals         JobContractAnimal[]
  completionRecord        JobCompletionRecord?
  ratings                 JobRating[]
  escrow                  Escrow?
  currencyDef             CurrencyDef?   @relation(fields: [currencyDefId], references: [id])
  workerPlayer            PlayerAccount  @relation("WorkerPlayer", fields: [workerPlayerId], references: [id])
  hirerPlayer             PlayerAccount  @relation("HirerPlayer", fields: [hirerPlayerId], references: [id])
  jobApplication          JobApplication @relation(fields: [jobApplicationId], references: [id])
  jobListing              JobListing     @relation(fields: [jobListingId], references: [id])
  game Game @relation(fields: [gameId], references: [id])
}

model JobContractAnimal {
  id String @id @default(cuid())
  contractId String
  animalId String
  animal Animal @relation(fields: [animalId], references: [id])
  contract JobContract @relation(fields: [contractId], references: [id])

  @@unique([contractId, animalId])
}

model JobCompletionRecord {
  id String @id @default(cuid())
  contractId String @unique
  completionPercent Float @default(0)
  lastCalculatedAt  DateTime @updatedAt
  contract JobContract @relation(fields: [contractId], references: [id])
}

model JobRating {
  id String @id @default(cuid())
  contractId String
  raterPlayerId String
  rateePlayerId String
  score         Int
  comment       String?
  rateePlayer PlayerAccount @relation("RateePlayer", fields: [rateePlayerId], references: [id])
  raterPlayer PlayerAccount @relation("RaterPlayer", fields: [raterPlayerId], references: [id])
  contract JobContract @relation(fields: [contractId], references: [id])

  @@unique([contractId, raterPlayerId])
}