enum AnimalStatus {
  ALIVE
  ARCHIVED
  BURIED
}

enum AnimalSex {
  MALE
  FEMALE
}

enum BreedCategoryBadge {
  BASE
  SECONDARY
  CUSTOM
}

model Species {
    id     String @id @default(cuid())
    gameId String
    name   String
    breeds Breed[]
    game   Game   @relation(fields: [gameId], references: [id])
    @@unique([gameId, name])
}

model LifeStageDef {
  id                 String  @id @default(cuid())
  gameId             String
  name               String
  stageIndex         Int
  minCycle           Int
  maxCycle           Int
  canCompete         Boolean
  canBreed           Boolean
  canTrain           Boolean
  canReceiveCare     Boolean
  hasUniqueActionSet Boolean @default(false)
  profileLayout      String
  game               Game    @relation(fields: [gameId], references: [id])
  @@unique([gameId, stageIndex])
}

model StatDef {
  id     String @id @default(cuid())
  gameId String
  name   String
  game   Game   @relation(fields: [gameId], references: [id])
  @@unique([gameId, name])
}

model Breed {
  id                     String         @id @default(cuid())
  gameId                 String
  name                   String
  speciesId              String
  categoryBadge          BreedCategoryBadge
  foundingPlayerId       String?
  image                  String?
  lore                   String?
  isUnregistered         Boolean @default(false)
  convergenceGenerations Int?
  game                   Game           @relation(fields: [gameId], references: [id])
  species                Species        @relation(fields: [speciesId], references: [id])
  foundingPlayer         PlayerAccount? @relation("BreedFounder", fields: [foundingPlayerId], references: [id])
  @@unique([breedId, statDefId])
}

model BreedStatProfile {
  id             String @id @default(cuid())
}

model Animal {
  id             String @id @default(cuid())
}

model AnimalStat {
  id             String @id @default(cuid())
}

model AnimalStatHistory {
  id             String @id @default(cuid())
}

model AnimalImage {
  id             String @id @default(cuid())
}

model AnimalAncestor {
  id             String @id @default(cuid())
}

model AnimalBreedComposition {
  id             String @id @default(cuid())
}

model GameInnateMax {
  id             String @id @default(cuid())
}

model PlayerBrand {
  id             String @id @default(cuid())
}

model AnimalBrand {
  id             String @id @default(cuid())
}

model AnimalDailyLog {
  id             String @id @default(cuid())
}
