enum AnimalStatus {
  ALIVE
  ARCHIVED
  BURIED
}

enum AnimalSex {
  MALE
  FEMALE
}

enum BreedCategoryBadge {
  BASE
  SECONDARY
  CUSTOM
}

model Species {
  id     String  @id @default(cuid())
  gameId String
  name   String
  breeds Breed[]
  game   Game    @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model LifeStageDef {
  id                 String             @id @default(cuid())
  gameId             String
  name               String
  stageIndex         Int
  minCycle           Int
  maxCycle           Int
  canCompete         Boolean
  canBreed           Boolean
  canTrain           Boolean
  canReceiveCare     Boolean
  hasUniqueActionSet Boolean            @default(false)
  profileLayout      String
  animals            Animal[]
  stageActivityDefs  StageActivityDef[]
  game               Game               @relation(fields: [gameId], references: [id])

  @@unique([gameId, stageIndex])
}

model StatDef {
  id                          String              @id @default(cuid())
  gameId                      String
  name                        String
  statProfiles                BreedStatProfile[]
  animalStats                 AnimalStat[]
  statHistoryLogs             AnimalStatHistory[]
  trainingActionDefs          TrainingActionDef[]
  breedingListingStatMinimums BreedingListingStatMinimum[]
  game                        Game                @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model Breed {
  id                          String                    @id @default(cuid())
  gameId                      String
  name                        String
  speciesId                   String
  categoryBadge               BreedCategoryBadge
  foundingPlayerId            String?
  image                       String?
  lore                        String?
  isUnregistered              Boolean                   @default(false)
  convergenceGenerations      Int?
  statProfile                 BreedStatProfile[]
  animals                     Animal[]
  animalBreedCompositions     AnimalBreedComposition[]
  alleleFrequencies           BreedAlleleFrequency[]
  conformationScores          AnimalConformationScore[]
  breedingListingRestrictions BreedingListingBreedRestriction[]
  game                        Game                      @relation(fields: [gameId], references: [id])
  species                     Species                   @relation(fields: [speciesId], references: [id])
  foundingPlayer              PlayerAccount?            @relation("BreedFounder", fields: [foundingPlayerId], references: [id])

  @@unique([gameId, name])
}

model BreedStatProfile {
  id         String  @id @default(cuid())
  breedId    String
  statDefId  String
  weight     Float
  naturalMin Float
  naturalMax Float
  baseline   Float
  breed      Breed   @relation(fields: [breedId], references: [id])
  statDef    StatDef @relation(fields: [statDefId], references: [id])

  @@unique([breedId, statDefId])
}

model Animal {
  id                              String                     @id @default(cuid())
  gameId                          String
  playerAccountId                 String
  breedId                         String
  name                            String
  sex                             AnimalSex
  lifeStageId                     String
  image                           String?
  generation                      Int                        @default(1)
  ageInCycles                     Int                        @default(0)
  bornAt                          DateTime                   @default(now())
  diedAt                          DateTime?
  causeOfDeath                    String?
  status                          AnimalStatus               @default(ALIVE)
  deletedAt                       DateTime?
  isCastrated                     Boolean                    @default(false)
  inbreedingCoefficient           Float                      @default(0)
  fertility                       Float
  isTutorialAnimal                Boolean                    @default(false)
  breedGeneration                 Int?
  disciplineDefId                 String?
  subContainerId                  String?
  stats                           AnimalStat[]
  statHistory                     AnimalStatHistory[]
  ancestors                       AnimalAncestor[]           @relation("AnimalLineage")
  offspring                       AnimalAncestor[]           @relation("AncestorAnimals")
  breedComposition                AnimalBreedComposition[]
  brands                          AnimalBrand[]
  dailyLogs                       AnimalDailyLog[]           @relation("DailyLogAnimal")
  partnerLogs                     AnimalDailyLog[]           @relation("DailyLogPartner")
  genotypes                       AnimalGenotype[]
  conformationScores              AnimalConformationScore[]
  careScore                       AnimalCareScore?
  longTermCareRecords             AnimalLongTermCareRecord[]
  behaviorEvents                  AnimalBehaviorEvent[]
  healthRecords                   AnimalHealthRecord[]
  treatmentRecords                AnimalTreatmentRecord[]
  activityRestrictions            ActivityRestriction[]
  testResults                     AnimalTestResult[]
  healthCertificates              HealthCertificate[]
  vetVisitLogs                    VetVisitLog[]
  immunity                        AnimalImmunity?
  careLogs                        CareLog[]
  trainingLogs                    TrainingLog[]
  energy                          AnimalEnergy?
  condition                       AnimalCondition?
  mood                            AnimalMood?
  personality                     AnimalPersonality?
  stageActivityLogs               StageActivityLog[]
  clinicEntries                   ClinicEntry[]
  titles                          AnimalTitle[]
  equipment                       AnimalEquipment[]
  breedingListings                BreedingListing[]
  breedingRecordsAsSire           BreedingRecord[]           @relation("BreedingSire")
  breedingRecordsAsDam            BreedingRecord[]           @relation("BreedingDam")
  pregnancies                     Pregnancy[]
  pregnancyOffspring              PregnancyOffspring[]
  geneticMaterials                GeneticMaterial[]
  surrogacyRecordsAsBiologicalDam SurrogacyRecord[]
  game                            Game                       @relation(fields: [gameId], references: [id])
  playerAccount                   PlayerAccount              @relation(fields: [playerAccountId], references: [id])
  breed                           Breed                      @relation(fields: [breedId], references: [id])
  lifeStage                       LifeStageDef               @relation(fields: [lifeStageId], references: [id])
  createdAt                       DateTime                   @default(now())
  updatedAt                       DateTime                   @updatedAt
}

model AnimalStat {
  id           String  @id @default(cuid())
  animalId     String
  statDefId    String
  innateValue  Float
  trainedValue Float   @default(0)
  animal       Animal  @relation(fields: [animalId], references: [id])
  statDef      StatDef @relation(fields: [statDefId], references: [id])

  @@unique([animalId, statDefId])
}

model AnimalStatHistory {
  id           String  @id @default(cuid())
  animalId     String
  statDefId    String
  cycleNumber  Int
  trainedValue Float
  animal       Animal  @relation(fields: [animalId], references: [id])
  statDef      StatDef @relation(fields: [statDefId], references: [id])

  @@unique([animalId, statDefId, cycleNumber])
}

model AnimalAncestor {
  id         String @id @default(cuid())
  animalId   String
  ancestorId String
  depth      Int
  animal     Animal @relation("AnimalLineage", fields: [animalId], references: [id])
  ancestor   Animal @relation("AncestorAnimals", fields: [ancestorId], references: [id])

  @@unique([animalId, ancestorId])
}

model AnimalBreedComposition {
  id         String @id @default(cuid())
  animalId   String
  breedId    String
  percentage Float
  animal     Animal @relation(fields: [animalId], references: [id])
  breed      Breed  @relation(fields: [breedId], references: [id])

  @@unique([animalId, breedId])
}

model GameInnateMax {
  id             String   @id @default(cuid())
  gameId         String   @unique
  maxTotalInnate Float
  game           Game     @relation(fields: [gameId], references: [id])
  updatedAt      DateTime @updatedAt
}

model PlayerBrand {
  id              String        @id @default(cuid())
  playerAccountId String        @unique
  path            String
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])
  animalBrands    AnimalBrand[]
  createdAt       DateTime      @default(now())
}

model AnimalBrand {
  id            String      @id @default(cuid())
  animalId      String
  playerBrandId String
  appliedAt     DateTime    @default(now())
  animal        Animal      @relation(fields: [animalId], references: [id])
  playerBrand   PlayerBrand @relation(fields: [playerBrandId], references: [id])

  @@unique([animalId, playerBrandId])
}

model AnimalDailyLog {
  id              String   @id @default(cuid())
  cycleNumber     Int
  animalId        String
  eventType       String
  partnerAnimalId String?
  outcome         String?
  context         Json?
  itemDefId       String?
  animal          Animal   @relation("DailyLogAnimal", fields: [animalId], references: [id])
  partner         Animal?  @relation("DailyLogPartner", fields: [partnerAnimalId], references: [id])
  createdAt       DateTime @default(now())
}
