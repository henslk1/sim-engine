enum ProfileFieldKey {
  BIO 
  GROUPS 
  ACHIEVEMENTS 
  FORUM_ACTIVITY
  LEADERBOARD_PLACINGS
  MARKETPLACE_LISTINGS
  CLINICS
  PLAYER_SHOP
}

model PlayerProfile {
  id              String        @id @default(cuid())
  playerAccountId String        @unique
  bio             String?
  bannerPath      String?
  updatedAt       DateTime      @updatedAt
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])
}

model ProfileVisibilitySetting {
  id String @id @default(cuid())
  playerAccountId String
  fieldKey        ProfileFieldKey
  isVisible       Boolean       @default(true)
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])

  @@unique([playerAccountId, fieldKey])
}

model PlayerSeniority {
  id                String        @id @default(cuid())
  playerAccountId   String        @unique
  activeDaysPlayed  Int           @default(0)
  lastActiveDateAt  DateTime?
  tutorialCompleted Boolean       @default(false)
  gatesBypassesd    Boolean       @default(false)
  playerAccount     PlayerAccount @relation(fields: [playerAccountId], references: [id])
}

model TutorialStepDef {
  id                   String @id @default(cuid())
  gameId               String
  stepKey              String
  name                 String
  description          String?
  stepIndex            Int
  tutorialProgressions TutorialProgress[]
  game                 Game   @relation(fields: [gameId], references: [id])

  @@unique([gameIdm stepKey])
  @@unique([gameId, stepIndex])
}

model TutorialProgress {
  id              String          @id @default(cuid())
  playerAccountId String
  stepDefId       String
  completedAt     DateTime?
  stepDef         TutorialStepDef @relation(fields: [stepDefId], references: [id])
  playerAccount   PlayerAccount   @relation(fields: [playerAccountId], references: [id])

  @@unique([playerAccountId, stepDefId])
}

model AchievementDef {
  id                 String  @id @default(cuid())
  gameId             String
  achievementKey     String
  name               String
  description        String?
  iconPath           String?
  isSecret           Boolean @default(false)
  goalValue          Int     @default(1)
  playerAchievements PlayerAchievement[]
  game               Game    @relation(fields: [gameId], references: [id])

  @@unique([gameId, achievementKey])
}

model PlayerAchievement {
  id               String         @id @default(cuid())
  playerAccountId  String
  achievementDefId String
  progress         Int            @default(0)
  earnedAt         DateTime?
  achievementDef   AchievementDef @relation(fields: [achievementDefId], references: [id])
  playerAccount    PlayerAccount  @relation(fields: [playerAccountId], references: [id])
}

model PlayerReputation {
  id              String        @id @default(cuid())
  playerAccountId String
  averageRating   Float         @default(0)
  totalRatings    Int           @default(0)
  lastUpdatedAt   DateTime      @default(now())
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])
}