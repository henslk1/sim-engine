enum ProfileFieldKey {
  BIO 
  GROUPS 
  ACHIEVEMENTS 
  FORUM_ACTIVITY
  LEADERBOARD_PLACINGS
  MARKETPLACE_LISTINGS
  CLINICS
  PLAYER_SHOP
}

model PlayerProfile {
  id              String        @id @default(cuid())
  playerAccountId String        @unique
  bio             String?
  bannerPath      String?
  updatedAt       DateTime      @updatedAt
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])
}

model ProfileVisibilitySetting {
  id String @id @default(cuid())
  playerAccountId String
  fieldKey        ProfileFieldKey
  isVisible       Boolean       @default(true)
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])

  @@unique([playerAccountId, fieldKey])
}

model PlayerSeniority {
  id                String        @id @default(cuid())
  playerAccountId   String        @unique
  activeDaysPlayed  Int           @default(0)
  lastActiveDateAt  DateTime?
  tutorialCompleted Boolean       @default(false)
  gatesBypassesd    Boolean       @default(false)
  playerAccount     PlayerAccount @relation(fields: [playerAccountId], references: [id])
}

model TutorialStepDef {
  id String @id @default(cuid())
}

model TutorialProgress {
  id String @id @default(cuid())
}

model AchievementDef {
  id String @id @default(cuid())
}

model PlayerAchievement {
  id String @id @default(cuid())
}

model PlayerReputation {
  id String @id @default(cuid())
}