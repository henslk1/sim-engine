enum BreedProposalStatus {
  PENDING_REVIEW
  APPROVED 
  REJECTED 
  IN_VOTE 
  SELECTED
}

enum BreedCampaignStatus {
  ACTIVE 
  COMPLETED
}

enum  CampaignPhaseType {
  ANNOUNCEMENT 
  FOUNDATION
  PROVING
  GROWTH
  RECOGNITION
}

enum PhaseTriggerType {
  TIME
  ADMIN_MANUAL
}

enum AnimalStatMode {
  BREED_MAX
  FLOOR 
  EXACT
}

enum PersonalityMode {
  RANDOM
  RANGE
}

enum CampaignRewardStatus {
  PENDING 
  DISTRIBUTED
}

model BreedProposal {
  id String @id @default(cuid())
}

model BreedProposalVote {
  id String @id @default(cuid())
}

model BreedCampaign {
  id String @id @default(cuid())
}

model CampaignPhaseDef {
  id String @id @default(cuid())
}

model campaignContribution {
  id String @id @default(cuid())
}

model FoundationAnimal {
  id String @id @default(cuid())
}

model AnimalTemplate {
  id              String  @id @default(cuid())
  gameId          String
  breedId         String
  statMode        AnimalStatMode
  statFloor       Float?
  healthClear     Boolean @default(false)
  personalityMode PersonalityMode
  personalityMin  Float?
  personalityMax  Float?
  genotype        AnimalTemplateGenotype[]
  rewardTiers     CampaignRewardTier[]
  breed           Breed   @relation(fields: [breedId], references: [id])
  game            Game    @relation(fields: [gameId], references: [id])
}

model AnimalTemplateGenotype {
  id          String    @id @default(cuid())
  templateId  String
  locusId     String
  alleleOneId String
  alleleTwoId String
  alleleTwo   AlleleTwo @relation("TemplateAlleleTwo", fields: [alleleTwoId], references: [id])
  alleleOne   AlleleOne @relation("TemplateAlleleOne", fields: [alleleOneId], references: [id])
  locus       Locus     @relation(fields: [locusId], references: [id])
  template    Template  @relation(fields: [templateId], references: [id])

  @@unique([templateId, locusId])
}

model CampaignRewardTier {
  id                   String          @id @default(cuid())
  campaignId           String
  tierName             String
  tierIndex            String
  minRank              Int
  maxRank              Int?
  animalTemplateId     String?
  breedingSlotsAwarded Int             @default(0)
  currencyRewards      CampaignRewardTierCurrency[]
  itemRewards          CampaignRewardTierItem[]
  rewardRecords        CampaignRewardRecord[]
  animalTemplate       AnimalTemplate? @relation(fields: [animalTemplateId], references: [id])
  campaign             BreedCampaign   @relation(fields: [campaignId], references: [id])
}

model CampaignRewardTierCurrency {
  id            String      @id @default(cuid())
  tierId        String
  currencyDefId String
  amount        Int
  currencyDef   CurrencyDef @relation(fields: [currencyDefId], references: [id])
  tier          Tier        @relation(fields: [tierId], references: [id])

  @@unique([tierId, currencyDefId])
}

model CampaignRewardTierItem {
  id        String             @id @default(cuid())
  tierId    String
  itemDefId String
  quantity  Int
  itemDef   ItemDef            @relation(fields: [itemDefId], references: [id])
  tier      CampaignRewardTier @relation(fields: [tierId], references: [id])

  @@unique([tierId, itemDefId])
}

model CampaignRewardRecord {
  id                String               @id @default(cuid())
  campaignId        String
  tierId            String
  recipientPlayerId String
  status            CampaignRewardStatus @default(PENDING)
  distributedAt     DateTime? 
  recipientPlayer   PlayerAccount        @relation(fields: [recipientPlayerId], references: [id])
  tier              CampaignRewardTier   @relation(fields: [tierId], references: [id])
  campaign          BreedCampaign        @relation(fields: [campaignId], references: [id])
}

model BreedDqTrait {
  id         String @id @default(cuid())
  breedId    String
  locusId    String
  expression String
  locus      Locus  @relation(fields: [locusId], references: [id])
  breed      Breed  @relation(fields: [breedId], references: [id])

  @@unique([breedId, locusId, expression])
}