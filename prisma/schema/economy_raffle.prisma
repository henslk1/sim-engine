enum RaffleHostType {
  ADMIN 
  PLAYER 
  GROUP
}

model Raffle {
  id               String         @id @default(cuid())
  gameId           String
  name             String
  ticketPrice      Int?
  currencyDefId    String?
  maxTickets       Int?
  ticketsPerPlayer Int?
  hostType         RaffleHostType
  hostPlayerId     String?
  hostGroupId      String?
  startsAt         DateTime 
  endsAt           DateTime
  isDrawn          Boolean        @default(false)
  drawnAt          DateTime?
  entries          RaffleEntry[]
  prizes           RafflePrize[]
  itemConfigs      RaffleItemConfig[]
  itemSubmissions  RaffleItemSubmission[]
  winners          RaffleWinner[]
  hostPlayer       PlayerAccount? @relation(fields: [hostPlayerId], references: [id])
  currencyDef      CurrencyDef?   @relation(fields: [currencyDefId], references: [id])
  game Game @relation(fields: [gameId], references: [id])
}

model RaffleEntry {
  id              String        @id @default(cuid())
  raffleId        String
  playerAccountId String
  ticketCount     Int
  purchasedAt     DateTime      @default(now())
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])
  raffle          Raffle        @relation(fields: [raffleId], references: [id])
  @@unique([raffleId, playerAccountId])
}

model RaffleItemConfig {
  id             String  @id @default(cuid())
  raffleId       String
  itemDefId      String
  ticketsPerItem Int
  totalCap       Int?
  perPlayerCap   Int?
  itemDef        ItemDef @relation(fields: [itemDefId], references: [id])
  raffle         Raffle  @relation(fields: [raffleId], references: [id])
  @@unique([raffleId, itemDefId])
}

model RaffleItemSubmission {
  id              String        @id @default(cuid())
  raffleId        String
  playerAccountId String
  itemDefId       String
  quantity        Int
  ticketsEarned   Int
  submittedAt     DateTime      @default(now())
  itemDef         ItemDef       @relation(fields: [itemDefId], references: [id])
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])
  raffle          Raffle        @relation(fields: [raffleId], references: [id])
}

model RafflePrize {
  id               String @id @default(cuid())
  raffleId         String
  placement        Int
  items            RafflePrizeItem[]
  animals          RafflePrizeAnimal[]
  geneticMaterials RafflePrizeGeneticMaterial[]
  currencies       RafflePrizeCurrency[]
  raffle           Raffle @relation(fields: [raffleId], references: [id])
  @@unique([raffleId, placement])
}

model RafflePrizeItem {
  id            String      @id @default(cuid())
  rafflePrizeId String
  itemDefId     String
  quantity      Int
  itemDef       ItemDef     @relation(fields: [itemDefId], references: [id])
  rafflePrize   RafflePrize @relation(fields: [rafflePrizeId], references: [id])
  @@unique([rafflePrizeId, itemDefId])
}

model RafflePrizeAnimal {
  id            String      @id @default(cuid())
  rafflePrizeId String
  animalId      String?
  breedId       String?
  quantity      Int         @default(1)
  breed         Breed?      @relation(fields: [breedId], references: [id])
  animal        Animal?     @relation(fields: [animalId], references: [id])
  rafflePrize   RafflePrize @relation(fields: [rafflePrizeId], references: [id])
}

model RafflePrizeGeneticMaterial {
  id                String          @id @default(cuid())
  rafflePrizeId     String
  geneticMaterialId String
  geneticMaterial   GeneticMaterial @relation(fields: [geneticMaterialId], references: [id])
  rafflePrize       RafflePrize     @relation(fields: [rafflePrizeId], references: [id])
  @@unique([rafflePrizeId, geneticMaterialId])
}

model RafflePrizeCurrency {
  id            String      @id @default(cuid())
  rafflePrizeId String
  currencyDefId String
  amount        Int
  currencyDef   CurrencyDef @relation(fields: [currencyDefId], references: [id])
  rafflePrize   RafflePrize @relation(fields: [rafflePrizeId], references: [id])
  @@unique([rafflePrizeId, currencyDefId])
}

model RaffleWinner {
  id              String        @id @default(cuid())
  raffleId        String
  playerAccountId String
  placement       Int
  claimedAt       DateTime?
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])
  raffle          Raffle        @relation(fields: [raffleId], references: [id])
  @@unique([raffleId, placement])
}