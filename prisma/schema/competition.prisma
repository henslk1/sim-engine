enum VenueClimate {
  WARM
  COLD
  TEMPERATE
}

enum VenueTerrain {
  FLAT
  COASTAL
  HILLY
  MOUNTAIN
}

enum CompetitionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED 
  CANCELLED
}

enum SeasonCategoryType {
  OVERALL
  PER_BREED
  PER_DISCIPLINE
}

enum RankSubjectType {
  PLAYER 
  GROUP
}

model DisciplineDef {
  id String @id @default(cuid())
  gameId String
  name   String
  description String?
  isConformation Boolean @default(false)
  statWeights      DisciplineStatWeight[]
  compTierDefs CompTierDef[]
  venueDisciplines VenueDiscipline[]
  competitions     Competition[]
  animalCompTiers  CompetitionTierDef[]
  weeklyPoints    
  seasonCategories
  recordDefs
  titleDefs
  animals
  game Game @relation(fields: [gameId], references: [id])
  @@unique([gameId, name])
}

model DisciplineStatWeight {
  id              String        @id @default(cuid())
  disciplineDefId String
  statDefId       String
  weight          Float
  statDef         StatDef       @relation(fields: [statDefId], references: [id])
  disciplineDef   DisciplineDef @relation(fields: [disciplineDefId], references: [id])
  @@unique([disciplineDefId, statDefId])
}