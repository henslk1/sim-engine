enum VenueClimate {
  HOT
  WARM
  COLD
  TEMPERATE
}

enum VenueTerrain {
  FLAT
  COASTAL
  HILLY
  MOUNTAIN
}

enum CompetitionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED 
  CANCELLED
}

enum SeasonCategoryType {
  OVERALL
  PER_BREED
  PER_DISCIPLINE
}

enum RankSubjectType {
  PLAYER 
  GROUP
}

model DisciplineDef {
  id               String @id @default(cuid())
  gameId           String
  name             String
  description      String?
  isConformation   Boolean @default(false)
  statWeights      DisciplineStatWeight[]
  compTierDefs     CompetitionTierDef[]
  venueDisciplines VenueDiscipline[]
  competitions     Competition[]
  animalCompTiers  AnimalCompetitionTier[]
  weeklyPoints     AnimalWeeklyPoints[]
  seasonCategories SeasonCategory[]
  recordDefs       RecordDef[]
  titleDefs        TitleDef[]
  animals          Animal[]
  game             Game @relation(fields: [gameId], references: [id])
  @@unique([gameId, name])
}

model DisciplineStatWeight {
  id              String        @id @default(cuid())
  disciplineDefId String
  statDefId       String
  weight          Float
  statDef         StatDef       @relation(fields: [statDefId], references: [id])
  disciplineDef   DisciplineDef @relation(fields: [disciplineDefId], references: [id])
  @@unique([disciplineDefId, statDefId])
}

model BreedConformationStandard {
  id                   String @id @default(cuid())
  breedId              String
  locusId              String
  idealExpressionLabel String
  weight               Float
  locus                Locus  @relation(fields: [locusId], references: [id])
  breed                Breed  @relation(fields: [breedId], references: [id])
  @@unique([breedId, locusId])
}

model CompetitionTierDef {
  id                   String        @id @default(cuid())
  gameId               String
  disciplineDefId      String
  name                 String
  tierIndex            Int
  minScore             Float?
  advancementThreshold Float?
  animalTiers          AnimalCompetitionTier[]
  disciplineDef        DisciplineDef @relation(fields: [disciplineDefId], references: [id])
  game                 Game          @relation(fields: [gameId], references: [id])
  @@unique([disciplineDefId, tierIndex])
}

model Venue {
  id           String @id @default(cuid())
  gameId       String
  name         String
  climate      VenueClimate
  terrain      VenueTerrain
  disciplines  VenueDiscipline[]
  competitions Competition[]
  game         Game  @relation(fields: [gameId], references: [id])
  @@unique([gameId, name])
}

model VenueDiscipline {
  id              String        @id @default(cuid())
  venueId         String
  disciplineDefId String
  disciplineDef   DisciplineDef @relation(fields: [disciplineDefId], references: [id])
  venue           Venue         @relation(fields: [venueId], references: [id])
  @@unique([venueId, disciplineDefId])
}

model ExpressionClimateModifier {
  id               String @id @default(cuid())
  expressionRuleId String
  climate          VenueClimate
  modifier         Float
  expressionRule   ExpressionRule @relation(fields: [expressionRuleId], references: [id])
  @@unique([expressionRuleId, climate])
}

model ExpressionTerrainModifier {
  id               String         @id @default(cuid())
  expressionRuleId String
  terrain          VenueTerrain
  modifier         Float
  expressionRule   ExpressionRule @relation(fields: [expressionRuleId], references: [id])
  @@unique([expressionRuleId, terrain])
}

model PrizeConfig {
  id            String      @id @default(cuid())
  competitionId String
  placement     Int
  currencyDefId String
  amount        Int
  competition   Competition @relation(fields: [competitionId], references: [id])
  @@unique([competitionId, placement])
}

model Season {
  id           String  @id @default(cuid())
  gameId       String
  name         String
  startsAt     DateTime
  endsAt       DateTime
  isActive     Boolean @default(false)
  categories   SeasonCategory[]
  rankings     SeasonRanking[]
  competitions Competition[]
  game         Game    @relation(fields: [gameId], references: [id])
}

model SeasonCategory {
  id              String         @id @default(cuid())
  seasonId        String
  name            String
  categoryType    SeasonCategoryType
  breedId         String?
  disciplineDefId String?
  rankings        SeasonRanking[]
  disciplineDef   DisciplineDef? @relation(fields: [disciplineDefId], references: [id])
  breed           Breed?         @relation(fields: [breedId], references: [id])
  season          Season         @relation(fields: [seasonId], references: [id])
  @@unique([seasonId, name])
}

model RecordDef {
  id              String        @id @default(cuid())
  gameId          String
  name            String
  description     String?
  recordType      String
  subjectType     String
  disciplineDefId String?
  breedId         String?
  statDefId       String?
  entries         RecordEntry[]
  statDef         StatDef?       @relation(fields: [statDefId], references: [id])
  breed           Breed?         @relation(fields: [breedId], references: [id])
  disciplineDef   DisciplineDef? @relation(fields: [disciplineDefId], references: [id])
  game            Game           @relation(fields: [gameId], references: [id])
  @@unique([gameId, name])
}

model DirectoryFilterDef {
  id           String  @id @default(cuid())
  gameId       String
  filterKey    String
  displayLabel String
  filterType   String
  isEnabled    Boolean @default(true)
  sortOrder    Int?
  game         Game    @relation(fields: [gameId], references: [id])
  @@unique([gameId, filterKey])
}

model Competition {
  id              String        @id @default(cuid())
  gameId          String
  venueId         String
  disciplineDefId String
  seasonId        String?
  name            String
  minEntries      Int
  maxWaitHours    Int
  status          CompetitionStatus
  isInvitational  Boolean       @default(false)
  entries         CompetitionEntry[]
  prizeConfigs    PrizeConfig[]
  season          Season?       @relation(fields: [seasonId], references: [id])
  disciplineDef   DisciplineDef @relation(fields: [disciplineDefId], references: [id])
  venue           Venue         @relation(fields: [venueId], references: [id])
  game            Game          @relation(fields: [gameId], references: [id])
  createdAt       DateTime      @default(now())
}

model CompetitionEntry {
  id              String        @id @default(cuid())
  competitionId   String
  animalId        String
  playerAccountId String
  enteredAt       DateTime      @default(now())
  result          CompetitionResult?
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])
  animal          Animal        @relation(fields: [animalId], references: [id])
  competition     Competition   @relation(fields: [competitionId], references: [id])
  @@unique([competitionId, animalId])
}

model CompetitionResult {
  id        String           @id @default(cuid())
  entryId   String           @unique
  placement Int?
  score     Float
  entry     CompetitionEntry @relation(fields: [entryId], references: [id])
}

model AnimalCompetitionTier {
  id              String @id @default(cuid())
  animalId        String
  disciplineDefId String
  tierDefId       String
  tierDef         CompetitionTierDef @relation(fields: [tierDefId], references: [id])
  disciplineDef   DisciplineDef @relation(fields: [disciplineDefId], references: [id])
  animal          Animal @relation(fields: [animalId], references: [id])
  @@unique([animalId, disciplineDefId])
}

model AnimalWeeklyPoints {
  id              String        @id @default(cuid())
  animalId        String
  disciplineDefId String
  weekStart       DateTime
  points          Float
  disciplineDef   DisciplineDef @relation(fields: [disciplineDefId], references: [id])
  animal          Animal        @relation(fields: [animalId], references: [id])
  @@unique([animalId, disciplineDefId, weekStart])
}

model SeasonRanking {
  id              String         @id @default(cuid())
  seasonId        String
  categoryId      String
  subjectTypeId   RankSubjectType
  playerAccountId String?
  groupId         String?
  rank            Int
  score           Float
  playerAccount   PlayerAccount? @relation(fields: [playerAccountId], references: [id])
  category        SeasonCategory       @relation(fields: [categoryId], references: [id])
  season          Season         @relation(fields: [seasonId], references: [id])
}

model RecordEntry {
    id              String         @id @default(cuid())
    recordDefId     String
    playerAccountId String?
    animalId        String?
    groupId         String?
    value           Float
    setAt           DateTime       @default(now())
    animal          Animal?        @relation(fields: [animalId], references: [id])
    playerAccount   PlayerAccount? @relation(fields: [playerAccountId], references: [id])
    recordDef       RecordDef      @relation(fields: [recordDefId], references: [id])
}