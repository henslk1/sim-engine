enum CurrencyType {
  BASE
  PREMIUM
  PRESTIGE
}

enum TransactionType {
  PURCHASE
  PRIZE
  BREEDING_FEE
  COMPETITION_ENTRY
  MARKETPLACE_SALE
  MARKETPLACE_PURCHASE
  STORE_PURCHASE
  CARE_FEE
  VET_SERVICE_FEE
  ESCROW_HOLD
  ESCROW_RELEASE
  ESCROW_REFUND
  CURRENCY_EXCHANGE
  RAFFLE_TICKET
  GIFT
  SUBSCRIPTION
  ADMIN_ADJUSTMENT
  GROUP_CONTRIBUTION
  GROUP_TREASURY_PAYOUT
  GROUP_CARE_CHARGE
}

model CurrencyDef {
  id                           String                  @id @default(cuid())
  gameId                       String
  name                         String
  currencyType                 CurrencyType
  symbol                       String?
  playerBalances               PlayerBalance[]
  transactions                 Transaction[]
  breedingListings             BreedingListing[]
  storeListing                 StoreListing[]
  vetServiceDefs               VetServiceDef[]
  bundleCurrencyRewards        BundleCurrencyReward[]
  shopBreedConfigs             GameShopBreedConfig[]
  marketplaceListings          MarketplaceListing[]
  marketplaceOffers            MarketplaceOffer[]
  toCurrencyOrders             CurrencyExchangeOrder[] @relation("ToCurrency")
  fromCurrencyOrders           CurrencyExchangeOrder[] @relation("FromCurrency")
  escrows                      Escrow[]
  gifts                        Gift[]
  rafflePrizeCurrencies        RafflePrizeCurrency[]
  raffles                      Raffle[]
  groupFinances                GroupFinance[]
  jobListings                  JobListing[]
  jobApplications              JobApplication[]
  jobContracts                 JobContract[]
  campaignRewardTierCurrencies CampaignRewardTierCurrency[]
  game                  Game                           @relation(fields: [gameId], references: [id])

  @@unique([gameId, name])
}

model PlayerBalance {
  id              String        @id @default(cuid())
  playerAccountId String
  currencyDefId   String
  balance         Int
  currencyDef     CurrencyDef   @relation(fields: [currencyDefId], references: [id])
  playerAccount   PlayerAccount @relation(fields: [playerAccountId], references: [id])

  @@unique([playerAccountId, currencyDefId])
}

model Transaction {
  id                    String          @id @default(cuid())
  gameId                String
  fromPlayerAccountId   String?
  toPlayerAccountId     String?
  fromGroupId           String?
  toGroupId             String?
  actingPlayerAccountId String?
  currencyDefId         String
  amount                Int
  txnType               TransactionType
  createdAt             DateTime        @default(now())
  toPlayerAccount       PlayerAccount?  @relation("TxnTo", fields: [toPlayerAccountId], references: [id])
  fromPlayerAccount     PlayerAccount?  @relation("TxnFrom", fields: [fromPlayerAccountId], references: [id])
  fromGroup             Group?          @relation("TxnFromGroup", fields: [fromGroupId], references: [id])
  toGroup               Group?          @relation("TxnToGroup", fields: [toGroupId], references: [id])
  actingPlayer          PlayerAccount?  @relation("ActingPlayer", fields: [actingPlayerAccountId], references: [id])
  currencyDef           CurrencyDef     @relation(fields: [currencyDefId], references: [id])
  game                  Game            @relation(fields: [gameId], references: [id])
}
